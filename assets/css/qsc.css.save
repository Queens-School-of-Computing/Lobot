@import url('https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap');

* {
	font-family: 'Open Sans';
}

body {
	overflow-x: hidden;
}

#qsc-logo a {
	width: 312px;
	display: block;
	height: 70px;
	background-image: url('/assets/images/QSC-logo-lockup.png');
	background-size: contain;
	background-repeat: no-repeat;
}

nav {
	background-color: #002452 !important;
	padding: 10px 30px !important;
	color: white;
}

.navbar-nav .nav-link {
	color: white !important;
}

.navbar-nav .nav-link:hover {
	background: white !important;
	color: black !important;
}

#dark-theme-toggle {
	color: white;
}

#logout {
	color: white;
	border-color: white;
}

#logout:hover {
	color: black;
	background-color: #fabd0f;
	border-color: #fabd0f;
}

.qu-bars {
        margin-bottom: 50px;
}

.qu-bars div {
	height: 5px;
}

.qu-bars .qu-red {
	background: #b90e31;
}

.qu-bars .qu-yellow {
	background: #fabd0f;
}

.form-group {
	margin: 25px 0;
}

#react-admin-hook table tbody tr:first-child {
	*/display: none;*/
}

#react-admin-hook .card {
	overflow: scroll;
}

#react-admin-hook .card table {
	margin: 0 !important;
}




.btn-danger {
  --bs-btn-color: #fff;
  --bs-btn-bg: #d7191c;
  --bs-btn-border-color: #d7191c;
  --bs-btn-hover-color: #fff;
  --bs-btn-hover-bg: #b71518;
  --bs-btn-hover-border-color: #ac1416;
  --bs-btn-focus-shadow-rgb: 221, 60, 62;
  --bs-btn-active-color: #fff;
  --bs-btn-active-bg: #ac1416;
  --bs-btn-active-border-color: #a11315;
  --bs-btn-active-shadow: inset 0 3px 5px rgba(0, 0, 0, 0.125);
  --bs-btn-disabled-color: #fff;
  --bs-btn-disabled-bg: #d7191c;
  --bs-btn-disabled-border-color: #d7191c;
}
