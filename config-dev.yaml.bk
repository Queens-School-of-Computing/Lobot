# Development environment overrides for config.yaml.bk
# Deploy with: helm upgrade ... -f config.yaml.bk -f config-dev.yaml.bk
singleuser:
  image:
    tag: 13.0.2cudnn-2.20.0tf-matlab-ollama-claude-qsc-u24.04-20260313
hub:
  config:
    GitHubOAuthenticator:
      oauth_callback_url: https://lobot-dev.cs.queensu.ca/hub/oauth_callback
  extraEnv:
    LOBOT_RUNTIME_URL: "https://cdn.jsdelivr.net/gh/Queens-School-of-Computing/Lobot@main/runtime_setting.yaml"
    LOBOT_ANNOUNCEMENT_URL: "https://cdn.jsdelivr.net/gh/Queens-School-of-Computing/Lobot@main/announcement.yaml"
    LOBOT_GROUP_ROLES_URL: "https://cdn.jsdelivr.net/gh/Queens-School-of-Computing/Lobot@main/group-roles.yaml"
    LOBOT_ANNOUNCEMENT_KEY: "announcement_dev"
