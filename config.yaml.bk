# This file can update the JupyterHub Helm chart's default configuration values.
#
# For reference see the configuration reference and default values, but make
# sure to refer to the Helm chart version of interest to you!
#
# Introduction to YAML:     https://www.youtube.com/watch?v=cdLNKUoMc6c
# Chart config reference:   https://zero-to-jupyterhub.readthedocs.io/en/stable/resources/reference.html
# Chart default values:     https://github.com/jupyterhub/zero-to-jupyterhub-k8s/blob/HEAD/jupyterhub/values.yaml
# Available chart versions: https://hub.jupyter.org/helm-chart/
#
proxy:
  secretToken: ""
  service:
    type: NodePort
    nodePorts:
      http: 30080
      https: 30443

cull:
  enabled: true
  timeout: 259200      # 72 hours of inactivity idle
  every: 300           # check every 5 min
  concurrency: 5
  maxAge: 0
  removeNamedServers: true
  users: false
  adminUsers: false

singleuser:
  #profileList:
  #  - display_name: "GPU Server"
  #    description: "Spawns a notebook server with access to a GPU"
  #    kubespawner_override:
  #      extra_resource_limits:
  #        nvidia.com/gpu: "1"
  lifecycleHooks:
    postStart:
      exec:
        command:
          - "sh"
          - "-c"
          - >
            curl https://raw.githubusercontent.com/Queens-School-of-Computing/Lobot/main/setup_desktop.sh | bash
  image:
    name: queensschoolofcomputingdocker/gpu-jupyter-latest
    tag: 13.0.2cudnn-2.20.0tf-matlab-ollama-claude-qsc-u24.04-20260313
  extraEnv:
    #Forsomereason this grant_sudo is not coming throug, so I have forced it in the start.sh file. 
    #GRANT_SUDO: "yes"
    #NOTEBOOK_ARGS: "--allow-root -e"
    NOTEBOOK_ARGS: "--allow-root"
  allowPrivilegeEscalation: true
  uid: 0
  #uid: 1000 
  cmd: start-singleuser.py
  storage:
    capacity: 50Gi
    dynamic:
      storageClass: caslab-retain-r1
    extraVolumes:
      - name: shm-volume
        emptyDir:
          medium: Memory
      - name: nfs-scratchdata
        hostPath:
          path: /mnt/scratchdata # Will be Readonly and blank unless nfs mounted from the host 
    extraVolumeMounts:
      - name: shm-volume
        mountPath: /dev/shm
      - name: nfs-scratchdata
        mountPath: /home/jovyan/scratchdata #The mountpoint inside the container
  extraFiles:
    jupyter_ydoc_config:
      mountPath: /usr/local/etc/jupyter/jupyter_server_config.py
      stringData: |
        c = get_config()  # noqa: F821
        c.YDocExtension.file_poll_interval = 0
        c.YDocExtension.document_cleanup_delay = 30
        c.YDocExtension.ystore_class = 'jupyter_server_ydoc.stores.TempFileYStore'


hub:
  config:
    GitHubOAuthenticator:
      auto_login: true
      client_id: xxx
      client_secret: xxx
      oauth_callback_url: http://lobot.cs.queensu.ca/hub/oauth_callback
      allowed_organizations:
        - Queens-School-of-Computing
        - TheBaleHouse
      admin_users:
        - WiegerTheFarmer
        - drdoog
        - sjwhittaker
        - jm-janzen 
      scope:
        - read:org
        - read:user
    JupyterHub:
      authenticator_class: github

  #Clone custom JupyterHub templates into a volume
  initContainers:
    - name: git-clone-templates
      image: alpine/git
      args:
        - clone
        - --single-branch
        - --branch=main
        - --depth=1
        - --
        - https://github.com/Queens-School-of-Computing/Lobot.git
        - /etc/jupyterhub/custom
      securityContext:
        #runAsUser: 0
        allowPrivilegeEscalation: true 
        runAsUser: 1000 
      volumeMounts:
        - name: custom-templates
          mountPath: /etc/jupyterhub/custom
  extraVolumes:
    - name: custom-templates
      emptyDir: {}
  extraVolumeMounts:
    - name: custom-templates
      mountPath: /etc/jupyterhub/custom
  extraConfig:
    05-services: |
      # Define the group-manager service with its API token
      c.JupyterHub.services += [
          {
              "name": "group-manager",
              "api_token": "xxx",  
          }
      ]
    10-group-roles-from-yaml: |
      import os, urllib.request, yaml

      GROUP_ROLES_URL = os.environ.get("LOBOT_GROUP_ROLES_URL", "https://raw.githubusercontent.com/Queens-School-of-Computing/Lobot/main/group-roles.yaml")

      # Global set of collaboration users, based on roles whose name starts with 'group-'
      _COLLAB_USERS = set()

      def _load_group_roles_and_service_role():
          global _COLLAB_USERS
          _COLLAB_USERS = set()

          try:
              raw = urllib.request.urlopen(GROUP_ROLES_URL).read().decode("utf-8")
              data = yaml.safe_load(raw) or {}
          except Exception as e:
              print(f"load_roles: failed to fetch {GROUP_ROLES_URL}: {e}")
              return []

          roles_cfg = data.get("roles", [])
          roles = []

          for r in roles_cfg:
              name = r.get("name")
              owner = r.get("user")
              members = r.get("members", []) or []
              if not (name and owner):
                  continue

              # any role whose name starts with "group-" is treated as a collab role
              if name.startswith("group-"):
                  _COLLAB_USERS.add(owner)

              # default scopes if none specified in YAML, open only, no start or stop
              default_scopes = [
                  f"access:servers!user={owner}",
              ]

              raw_scopes = r.get("scopes")
              if raw_scopes:
                  # substitute {user} with owner in each scope string
                  scopes = [s.format(user=owner) for s in raw_scopes]
              else:
                  scopes = default_scopes

              roles.append(
                  {
                      "name": name,
                      "scopes": scopes,
                      "users": members,
                  }
              )
          
          # Add the group-manager service role here
          roles.append(
              {
                  "name": "group-manager-role",
                  "scopes": [
                      "admin:users", # for adding new local users
                      "admin:groups",# for read/write group and membership
                  ],
                  "services": ["group-manager"],
              }
          )
          print(f"load_roles: feteched these roles in {GROUP_ROLES_URL}: {str(roles)}")
          print(f"collab-users-from-roles: collaboration users = {sorted(_COLLAB_USERS)}")
          return roles

      c.JupyterHub.load_roles += _load_group_roles_and_service_role()
    15-group-servers-template-vars: |
      import os, urllib.request, yaml

      GROUP_ROLES_URL = os.environ.get("LOBOT_GROUP_ROLES_URL", "https://raw.githubusercontent.com/Queens-School-of-Computing/Lobot/main/group-roles.yaml")

      def _load_group_servers_by_user():
          """
          Build mapping: member_username (lowercase) -> [
              {
                  "owner": group_user,
                  "running": None,       # unknown here
                  "can_manage": True,
              }, ...
          ]
          """
          try:
              raw = urllib.request.urlopen(GROUP_ROLES_URL).read().decode("utf-8")
              data = yaml.safe_load(raw) or {}
          except Exception as e:
              print(f"group-servers-template-vars: failed to fetch {GROUP_ROLES_URL}: {e}")
              return {}

          roles_cfg = data.get("roles", [])
          mapping = {}  # user -> [group dicts]

          for r in roles_cfg:
              group_user = r.get("user")
              members = r.get("members", []) or []
              if not group_user:
                  continue

              for m in members:
                  uname = m.strip().lower()
                  mapping.setdefault(uname, []).append(
                      {
                          "owner": group_user,
                          "running": None,    # we don't know running state here
                          "can_manage": True,
                      }
                  )

          return mapping

      c.JupyterHub.template_vars = getattr(c.JupyterHub, "template_vars", {})
      c.JupyterHub.template_vars["group_servers_by_user"] = _load_group_servers_by_user()
    16-dynamic-announcement: |
      import os, urllib.request, urllib.error, yaml
      from jupyterhub.handlers import BaseHandler

      ANNOUNCEMENT_URL = os.environ.get(
          "LOBOT_ANNOUNCEMENT_URL",
          "https://raw.githubusercontent.com/Queens-School-of-Computing/Lobot/main/announcement.yaml",
      )

      def _fetch_announcement():
          try:
              raw = urllib.request.urlopen(ANNOUNCEMENT_URL, timeout=3).read().decode("utf-8")
              data = yaml.safe_load(raw) or {}
          except Exception as e:
              # Don't break the page if the URL is unreachable
              print(f"[dynamic-announcement] Failed to fetch {ANNOUNCEMENT_URL}: {e}")
              return ""
          text = data.get(os.environ.get("LOBOT_ANNOUNCEMENT_KEY", "announcement_prod"), "") or ""
          return text

      _orig_render_template_announce = BaseHandler.render_template

      def _render_template_with_announcement(self, name, sync=False, **ns):
          try:
              ann = _fetch_announcement()
              # Only set if non-empty; templates can test 'announcement_home'
              if ann:
                  ns.setdefault("announcement_login", ann)
                  ns.setdefault("announcement_home", ann)
                  ns.setdefault("announcement_spawn", ann)
          except Exception as e:
              self.log.error(f"[dynamic-announcement] Error injecting announcement: {e}")
          return _orig_render_template_announce(self, name, sync=sync, **ns)

      BaseHandler.render_template = _render_template_with_announcement
    17-status-page: |
      import tornado.web, os, urllib.request, yaml, smtplib, html as _html
      from jupyterhub.handlers import BaseHandler
      from email.mime.multipart import MIMEMultipart
      from email.mime.text import MIMEText

      _RUNTIME_URL = os.environ.get(
          "LOBOT_RUNTIME_URL",
          "https://raw.githubusercontent.com/Queens-School-of-Computing/Lobot/main/runtime_setting.yaml"
      )
      _REQUEST_DEST = 'help@cs.queensu.ca'

      def _fetch_runtime():
          return yaml.safe_load(urllib.request.urlopen(_RUNTIME_URL, timeout=5).read().decode('utf-8')) or {}

      def _lab_options(supervisors):
          return [(k, v['display']) for k, v in supervisors.items() if k != 'devlab']

      def _email_html(tag_label, rows_html, message_html, supervisor_note_html=''):
          return (
              '<!DOCTYPE html><html><head><meta charset="utf-8"></head>'
              '<body style="margin:0;padding:0;background:#f5f5f5;font-family:sans-serif">'
              '<table width="100%" cellpadding="0" cellspacing="0" style="background:#f5f5f5;padding:32px 0">'
              '<tr><td align="center">'
              '<table width="600" cellpadding="0" cellspacing="0" style="background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.12)">'
              '<tr><td style="background:#2c3e50;padding:24px 32px">'
              '<span style="color:#fff;font-size:20px;font-weight:600">Lobot Cluster</span>'
              '<span style="color:#95a5a6;font-size:14px;margin-left:10px">Queen\'s School of Computing</span>'
              '</td></tr>'
              '<tr><td style="padding:24px 32px 0">'
              f'<span style="background:#e8f0fe;color:#1a56db;font-size:13px;font-weight:600;padding:4px 14px;border-radius:12px">{tag_label}</span>'
              '</td></tr>'
              '<tr><td style="padding:16px 32px 0">'
              '<table cellpadding="0" cellspacing="0" width="100%">'
              + rows_html
              + supervisor_note_html
              + '</table></td></tr>'
              '<tr><td style="padding:16px 32px"><hr style="border:none;border-top:1px solid #e9ecef;margin:0"></td></tr>'
              '<tr><td style="padding:0 32px 32px">'
              '<p style="margin:0 0 8px;color:#6c757d;font-size:12px;text-transform:uppercase;letter-spacing:0.5px">Message</p>'
              f'<div style="background:#f8f9fa;border-left:4px solid #2c3e50;padding:16px;border-radius:4px;font-size:14px;line-height:1.6;white-space:pre-wrap">{message_html}</div>'
              '</td></tr>'
              '<tr><td style="background:#f8f9fa;padding:16px 32px;border-top:1px solid #e9ecef">'
              '<p style="margin:0;font-size:11px;color:#6c757d">Sent via Lobot &mdash; lobot.cs.queensu.ca</p>'
              '</td></tr>'
              '</table></td></tr></table></body></html>'
          )

      def _supervisor_note_html(name, email):
          if not email:
              return ''
          esc_n = _html.escape(name or email)
          esc_e = _html.escape(email)
          return (
              '<tr><td colspan="2" style="padding:12px 0 0;font-size:12px;color:#6c757d">'
              f'<em>Note: {esc_n} ({esc_e}) has been included as a CC recipient on this '
              f'message for informative purposes.</em></td></tr>'
          )

      def _send_email(subject, body_html, reply_email, supervisor_email='', dest=None, json_attachment=None):
          to = dest or _REQUEST_DEST
          recipients = [to]
          msg = MIMEMultipart('mixed' if json_attachment else 'alternative')
          msg['Subject']  = subject
          msg['From']     = 'lobot@cs.queensu.ca'
          msg['To']       = to
          msg['Reply-To'] = reply_email
          if supervisor_email:
              msg['Cc'] = supervisor_email
              recipients.append(supervisor_email)
          msg.attach(MIMEText(body_html, 'html'))
          if json_attachment:
              from email.mime.application import MIMEApplication
              part = MIMEApplication(json_attachment.encode('utf-8'), _subtype='json')
              part.add_header('Content-Disposition', 'attachment', filename='access-request.json')
              msg.attach(part)
          with smtplib.SMTP('innovate.cs.queensu.ca', 25, timeout=5) as s:
              s.sendmail('lobot@cs.queensu.ca', recipients, msg.as_string())

      def _td(label, value_html):
          return (
              '<tr>'
              f'<td style="padding:6px 0;color:#6c757d;font-size:13px;width:140px">{label}</td>'
              f'<td style="padding:6px 0;font-size:13px;font-weight:500">{value_html}</td>'
              '</tr>'
          )


      class StatusPageHandler(BaseHandler):
          @tornado.web.authenticated
          async def get(self):
              import json
              user = self.current_user
              allowed_labs_json = 'null'  # null = admin, sees all
              if not user.admin:
                  try:
                      username = user.name.strip().lower()
                      self.log.info(f'[status-page] username={username}')
                      data = yaml.safe_load(urllib.request.urlopen(_RUNTIME_URL, timeout=3).read().decode('utf-8')) or {}
                      nodeaccess = data.get('nodeaccess', {})
                      lab_groups = data.get('lab_groups', {})
                      self.log.info(f'[status-page] nodeaccess keys={list(nodeaccess.keys())}')

                      def labs_for_user(uname):
                          return [lab for lab, users in nodeaccess.items()
                                  if uname in [u.strip().lower() for u in (users or [])]]

                      allowed = set(labs_for_user(username))
                      self.log.info(f'[status-page] direct labs={allowed}')

                      group_servers_by_user = self.template_namespace.get('group_servers_by_user', {})
                      self.log.info(f'[status-page] group_servers_by_user entry for {username}={group_servers_by_user.get(username)}')
                      for group in group_servers_by_user.get(username, []):
                          owner = (group.get('owner') or '').strip().lower()
                          group_labs = labs_for_user(owner)
                          self.log.info(f'[status-page] group owner={owner} labs={group_labs}')
                          if owner:
                              allowed.update(group_labs)

                      expanded = set()
                      for lab in allowed:
                          expanded.update(lab_groups.get(lab, [lab]))
                      allowed = expanded

                      self.log.info(f'[status-page] final allowed={sorted(allowed)}')
                      allowed_labs_json = json.dumps(sorted(allowed))
                  except Exception as e:
                      self.log.error(f'[status-page] Failed to build allowed labs: {e}')
              status_url = f"https://{self.request.host}/allocationstatus/current.json"
              html = await self.render_template('status.html', allowed_labs_json=allowed_labs_json, status_url=status_url)
              self.finish(html)


      class RequestPageHandler(BaseHandler):
          @tornado.web.authenticated
          async def get(self):
              user = self.current_user
              username = user.name.strip().lower() if user else ''
              xsrf = self.xsrf_token.decode('ascii') if isinstance(self.xsrf_token, bytes) else self.xsrf_token
              html = await self.render_template('request.html',
                  username=username, submitted=False, error=None, xsrf_token=xsrf)
              self.finish(html)

          @tornado.web.authenticated
          async def post(self):
              self.check_xsrf_cookie()
              user = self.current_user
              username = user.name.strip().lower() if user else 'unknown'
              request_type = self.get_body_argument('request_type', '').strip()
              reply_email  = self.get_body_argument('reply_email', '').strip()
              message      = self.get_body_argument('message', '').strip()
              xsrf = self.xsrf_token.decode('ascii') if isinstance(self.xsrf_token, bytes) else self.xsrf_token

              async def _render(submitted=False, error=None):
                  return await self.render_template('request.html',
                      username=username, submitted=submitted, error=error, xsrf_token=xsrf)

              if not request_type or not reply_email or not message:
                  self.finish(await _render(error='Please fill in all fields.'))
                  return

              supervisor_name, supervisor_email = '', ''
              try:
                  data = _fetch_runtime()
                  nodeaccess  = data.get('nodeaccess', {})
                  supervisors = data.get('supervisors', {})
                  user_lab = next(
                      (lab for lab, members in nodeaccess.items()
                       if username in [u.strip().lower() for u in (members or [])]),
                      None
                  )
                  if user_lab and user_lab in supervisors:
                      sv = supervisors[user_lab]
                      supervisor_name  = sv.get('supervisor_name', '')
                      supervisor_email = sv.get('supervisor_email', '')
              except Exception:
                  pass

              try:
                  esc_type  = _html.escape(request_type)
                  esc_user  = _html.escape(username)
                  esc_email = _html.escape(reply_email)
                  esc_msg   = _html.escape(message)
                  rows = (
                      _td('GitHub username', esc_user)
                      + _td('Reply to', f'<a href="mailto:{esc_email}" style="color:#1a56db">{esc_email}</a>')
                  )
                  body_html = _email_html(esc_type, rows, esc_msg,
                                          _supervisor_note_html(supervisor_name, supervisor_email))
                  _send_email(f'[Lobot Request] {request_type} from {username}',
                              body_html, reply_email, supervisor_email)
                  self.finish(await _render(submitted=True))
              except Exception as e:
                  self.log.error(f'[request-page] Failed to send email: {e}')
                  self.finish(await _render(error='Failed to send your request. Please email help@cs.queensu.ca directly.'))


      class AccessRequestHandler(BaseHandler):
          async def get(self):
              supervisors = {}
              try:
                  supervisors = _fetch_runtime().get('supervisors', {})
              except Exception:
                  pass
              user = self.current_user
              github_username = user.name.strip().lower() if user else ''
              xsrf = self.xsrf_token.decode('ascii') if isinstance(self.xsrf_token, bytes) else self.xsrf_token
              html = await self.render_template('access-request.html',
                  lab_options=_lab_options(supervisors), submitted=False, error=None,
                  xsrf_token=xsrf, github_username=github_username)
              self.finish(html)

          async def post(self):
              self.check_xsrf_cookie()
              supervisors = {}
              try:
                  supervisors = _fetch_runtime().get('supervisors', {})
              except Exception:
                  pass
              honeypot        = self.get_body_argument('website', '').strip()
              full_name       = self.get_body_argument('full_name', '').strip()
              github_username = self.get_body_argument('github_username', '').strip()
              net_id          = self.get_body_argument('net_id', '').strip()
              reply_email     = self.get_body_argument('reply_email', '').strip()
              lab_key         = self.get_body_argument('lab_key', '').strip()
              message         = self.get_body_argument('message', '').strip()
              xsrf = self.xsrf_token.decode('ascii') if isinstance(self.xsrf_token, bytes) else self.xsrf_token

              if honeypot:
                  ip = self.request.remote_ip
                  self.log.warning(f'[access-request] honeypot triggered from {ip}')
                  try:
                      esc_ip   = _html.escape(ip or 'unknown')
                      esc_hp   = _html.escape(honeypot[:200])
                      esc_name = _html.escape(full_name[:200])
                      esc_user = _html.escape(github_username[:200])
                      rows = (_td('IP address', esc_ip)
                              + _td('Honeypot value', esc_hp)
                              + _td('Name field', esc_name or '<em style="color:#6c757d">empty</em>')
                              + _td('GitHub field', esc_user or '<em style="color:#6c757d">empty</em>'))
                      body_html = _email_html('Honeypot', rows, '&mdash;')
                      _send_email('[Lobot] Honeypot triggered on access-request form',
                                  body_html, 'lobot@cs.queensu.ca',
                                  dest='aaron.visser@queensu.ca')
                  except Exception as e:
                      self.log.error(f'[access-request] Failed to send honeypot email: {e}')
                  self.finish(await self.render_template('access-request.html',
                      lab_options=_lab_options(supervisors), submitted=True, error=None,
                      xsrf_token=xsrf, github_username=github_username))
                  return

              async def _render(submitted=False, error=None):
                  return await self.render_template('access-request.html',
                      lab_options=_lab_options(supervisors), submitted=submitted, error=error,
                      xsrf_token=xsrf, github_username=github_username)

              if not full_name or not github_username or not reply_email or not lab_key:
                  self.finish(await _render(error='Please fill in all required fields.'))
                  return

              lab_info         = supervisors.get(lab_key, {}) or {}
              lab_display      = lab_info.get('display', lab_key)
              supervisor_name  = lab_info.get('supervisor_name', '')
              supervisor_email = lab_info.get('supervisor_email', '')

              try:
                  esc_name  = _html.escape(full_name)
                  esc_user  = _html.escape(github_username)
                  esc_netid = _html.escape(net_id) if net_id else '<em style="color:#6c757d">not provided</em>'
                  esc_email = _html.escape(reply_email)
                  esc_lab   = _html.escape(lab_display)
                  esc_msg   = _html.escape(message)
                  rows = (
                      _td('Name', esc_name)
                      + _td('GitHub username', esc_user)
                      + _td('NetID', esc_netid)
                      + _td('Reply to', f'<a href="mailto:{esc_email}" style="color:#1a56db">{esc_email}</a>')
                      + _td('Requested lab', esc_lab)
                  )
                  body_html = _email_html('Access Request', rows, esc_msg,
                                          _supervisor_note_html(supervisor_name, supervisor_email))

                  # Machine-readable payload, attached as access-request.json to
                  # every copy (and used as the machine-copy body) so the
                  # SharePoint Power Automate flow never parses styled HTML.
                  import json as _json
                  from datetime import datetime as _dtm, timezone as _tz
                  # first/last split matches the SharePoint list's separate
                  # name columns: last word = last name, rest = first name(s)
                  _name_parts = full_name.rsplit(None, 1)
                  payload_json = _json.dumps({
                      'kind': 'lobot-access-request',
                      'submitted_at': _dtm.now(_tz.utc).isoformat(timespec='seconds'),
                      'full_name': full_name,
                      'first_name': _name_parts[0] if len(_name_parts) > 1 else '',
                      'last_name': _name_parts[-1],
                      'github_username': github_username,
                      'net_id': net_id,
                      'email': reply_email,
                      'lab_key': lab_key,
                      'lab_display': lab_display,
                      'supervisor_name': supervisor_name,
                      'supervisor_email': supervisor_email,
                      'message': message,
                  }, indent=2)

                  _send_email(f'[Lobot Access Request] {github_username} - {lab_display}',
                              body_html, reply_email, supervisor_email,
                              json_attachment=payload_json)
                  self.finish(await _render(submitted=True))
              except Exception as e:
                  self.log.error(f'[access-request] Failed to send email: {e}')
                  self.finish(await _render(error='Failed to send your request. Please email help@cs.queensu.ca directly.'))


      c.JupyterHub.extra_handlers = [
          (r'/status',          StatusPageHandler),
          (r'/status/',         StatusPageHandler),
          (r'/request',         RequestPageHandler),
          (r'/request/',        RequestPageHandler),
          (r'/request-access',  AccessRequestHandler),
          (r'/request-access/', AccessRequestHandler),
      ]
    20-rtc: |
      # Make JupyterLab the default and enable RTC
      c.Spawner.default_url = "/lab"
      #AV Feb 17 2026 - don't need specific RTC flags. Images are updated to support it.      
      #c.ServerApp.collaborative = True
    templates: |
      c.JupyterHub.template_paths = ['/etc/jupyterhub/custom/templates/']
    debug: |
      # Set the log level by value or name.
      c.JupyterHub.log_level = 'DEBUG'

      c.JupyterHub.default_url = "/hub/home"

      # Enable debug-logging of the single-user server
      c.Spawner.debug = False 

      # add some extra timeouts
      # 480s covers the worst case for lobot_blackwell MIG repartitioning in
      # pre_spawn_hook: up to two poll cycles of MIG_STATE_POLL_TIMEOUT (180s
      # each, one retry on failure) plus normal pod start time.
      c.Spawner.http_timeout = 480
      c.Spawner.start_timeout = 480
      #c.Spawner.http_timeout = 3600
      #c.Spawner.start_timeout = 3600
      
      # Enable debug-logging of the single-user server
      c.LocalProcessSpawner.debug = False
      c.JupyterHub.api_page_default_limit = 200
    custom_options_form: |
      from kubespawner import KubeSpawner

      # MIG profiles available on the lobot_blackwell node. Keep in sync with
      # the gpu-operator `mig-config` ConfigMap and assets/labs.yaml
      # mig_profiles. Duplicated in pre_spawn_hook (extraConfig blocks don't
      # share Python state).
      MIG_PROFILES = {
        'all-disabled':    1,
        'all-1g.24gb':     4,
        'all-1g.24gb+gfx': 4,
        'all-1g.24gb+me':  1,
        'all-2g.48gb':     2,
        'all-2g.48gb+gfx': 2,
      }
      MIG_LAB = 'lobot_blackwell'
      MIG_NODE_LABEL_SELECTOR = 'lab=lobot_blackwell'

      def options_from_form(self, formdata):
        import urllib.request, yaml, os, re as _re, smtplib
        from email.mime.text import MIMEText

        username = self.user.name.strip().lower()

        def _send_violation_email(subject, body):
          try:
            msg = MIMEText(body)
            msg['Subject'] = subject
            msg['From'] = 'lobot@cs.queensu.ca'
            msg['To'] = 'aaron@cs.queensu.ca'
            with smtplib.SMTP('innovate.cs.queensu.ca', 25, timeout=5) as s:
              s.sendmail('lobot@cs.queensu.ca', ['aaron@cs.queensu.ca'], msg.as_string())
          except Exception:
            pass

        options = {}
        options['image'] = formdata['image']
        options['cpu_limit'] = formdata['cpu_limit']
        options['mem_limit'] = formdata['mem_limit']
        options['gpu_limit'] = formdata['gpu_limit']
        options['storage_class'] = formdata['storage_class']
        if 'mig_profile' in formdata:
          mig_profile = formdata['mig_profile'][0]
          if mig_profile not in MIG_PROFILES:
            raise ValueError(f'POLICY VIOLATION: "{mig_profile}" is not a recognized GPU partitioning mode.')
          options['mig_profile'] = formdata['mig_profile']

        # All validation runs before spawn-pending so errors show on the spawn form.
        # If the YAML fetch fails, silently pass — pre_spawn_hook will re-validate.
        lab = options['storage_class'][0].split('-')[0]
        RUNTIME_URL = os.environ.get("LOBOT_RUNTIME_URL", "https://raw.githubusercontent.com/Queens-School-of-Computing/Lobot/main/runtime_setting.yaml")
        try:
          data = yaml.safe_load(urllib.request.urlopen(RUNTIME_URL, timeout=5).read().decode('utf-8')) or {}

          # Validate image against allowed options for this lab
          lab_html = (data.get(f'from_data_{lab}') or '')
          _img_select = _re.search(
            r'<select[^>]+name=["\']image["\'][^>]*>(.*?)</select>',
            lab_html, flags=_re.DOTALL)
          if _img_select:
            _allowed_images = _re.findall(r'<option[^>]+value=["\']([^"\']*)["\']', _img_select.group(1))
            req_image = options['image'][0]
            if _allowed_images and req_image not in _allowed_images:
              _send_violation_email(
                f'[Lobot] Policy Violation: Unauthorized image by {username} on {lab}',
                f'GitHub user:     {username}\n'
                f'Lab:             {lab}\n'
                f'Attempted image: {req_image}\n'
                f'Allowed images:  {", ".join(_allowed_images)}\n'
              )
              raise ValueError(f'POLICY VIOLATION: Image "{req_image}" is not permitted on this system. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

          # Validate resource limits
          limits = (data.get('limits') or {}).get(lab)
          if limits:
            def parse_mem_gb(s):
              s = str(s).upper()
              if s.endswith('G'): return float(s[:-1])
              if s.endswith('M'): return float(s[:-1]) / 1024
              return float(s)

            req_gpu = int(options['gpu_limit'][0])
            if req_gpu < 0: req_gpu = 0
            max_gpu = int(limits.get('max_gpu', 0))
            if req_gpu > max_gpu:
              _send_violation_email(
                f'[Lobot] Policy Violation: GPU limit exceeded by {username} on {lab}',
                f'GitHub user: {username}\n'
                f'Lab:         {lab}\n'
                f'Requested:   {req_gpu} GPU(s)\n'
                f'Limit:       {max_gpu} GPU(s)\n'
              )
              raise ValueError(f'POLICY VIOLATION: Requested {req_gpu} GPU(s) exceeds your allocated limit of {max_gpu}. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

            if lab == MIG_LAB and 'mig_profile' in options:
              mig_profile = options['mig_profile'][0]
              max_slices = MIG_PROFILES.get(mig_profile, 0) * 6  # 6 physical GPUs on the node
              if req_gpu > max_slices:
                _send_violation_email(
                  f'[Lobot] Policy Violation: MIG slice count exceeded by {username} on {lab}',
                  f'GitHub user: {username}\n'
                  f'Lab:         {lab}\n'
                  f'MIG mode:    {mig_profile}\n'
                  f'Requested:   {req_gpu} GPU slice(s)\n'
                  f'Max for mode:{max_slices} GPU slice(s)\n'
                )
                raise ValueError(f'POLICY VIOLATION: Requested {req_gpu} GPU slice(s) exceeds the maximum of {max_slices} for MIG mode "{mig_profile}". Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

            req_cpu = float(options['cpu_limit'][0])
            max_cpu = float(limits.get('max_cpu', 0))
            if max_cpu > 0 and req_cpu > max_cpu:
              _send_violation_email(
                f'[Lobot] Policy Violation: CPU limit exceeded by {username} on {lab}',
                f'GitHub user: {username}\n'
                f'Lab:         {lab}\n'
                f'Requested:   {req_cpu} CPU cores\n'
                f'Limit:       {max_cpu} CPU cores\n'
              )
              raise ValueError(f'POLICY VIOLATION: Requested {req_cpu} CPU cores exceeds your allocated limit of {max_cpu}. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

            req_mem_gb = parse_mem_gb(options['mem_limit'][0])
            max_mem_gb = float(limits.get('max_mem_gb', 0))
            if max_mem_gb > 0 and req_mem_gb > max_mem_gb:
              _send_violation_email(
                f'[Lobot] Policy Violation: Memory limit exceeded by {username} on {lab}',
                f'GitHub user: {username}\n'
                f'Lab:         {lab}\n'
                f'Requested:   {req_mem_gb}G\n'
                f'Limit:       {max_mem_gb}G\n'
              )
              raise ValueError(f'POLICY VIOLATION: Requested {req_mem_gb}G memory exceeds your allocated limit of {max_mem_gb}G. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

        except ValueError:
          raise
        except Exception:
          pass  # Don't block spawn if YAML fetch fails; pre_spawn_hook will re-validate

        return options
      async def dynamic_form(self):
        import urllib.request, yaml, os, re

        data = yaml.safe_load(urllib.request.urlopen(
          os.environ.get("LOBOT_RUNTIME_URL",
            "https://raw.githubusercontent.com/Queens-School-of-Computing/Lobot/main/runtime_setting.yaml")
        ).read().decode('utf-8'))
        self.log.info(str(data))

        # Stamp nightly image options with the date of the last nightly build.
        # build_date comes from component-versions.json, pushed by the build
        # server after each changed nightly. Fail-soft: labels stay unstamped
        # if the fetch fails.
        try:
          import json as _json, datetime as _dt
          _manifest = _json.loads(urllib.request.urlopen(
            os.environ.get("LOBOT_VERSIONS_URL",
              "https://raw.githubusercontent.com/Queens-School-of-Computing/gpu-jupyter-latest/master/component-versions.json"),
            timeout=5).read().decode('utf-8'))
          _built = _dt.datetime.strptime(str(_manifest.get('build_date')), '%Y%m%d').strftime('%b %-d, %Y')
          for _k, _v in list(data.items()):
            if _k.startswith('from_data_') and isinstance(_v, str):
              data[_k] = _v.replace('(nightly)', '(nightly · updated ' + _built + ')')

          # Render a collapsible component-version summary under the image
          # select, from the same manifest (enriched fields written by
          # update_image_metadata.py — see BUILD-PUSH-QSCIMAGES.md, "Build
          # changelog"). Older manifests without pinned_common/images render
          # just the nightly-tools line. Injected HTML must not contain
          # literal braces — these templates go through .format() later.
          _tools = _manifest.get('components') or {}
          _pins = _manifest.get('pinned_common') or {}
          _imgs = _manifest.get('images') or {}
          _tool_names = {'vscode': 'VS Code', 'code_server': 'code-server',
                         'chrome': 'Chrome', 'ollama': 'Ollama',
                         'claude_code': 'Claude Code', 'opencode': 'opencode',
                         'uv': 'uv', 'selenium': 'Selenium'}
          _parts = []
          if _tools:
            _parts.append('<b>Developer tools</b> (refreshed nightly in "(nightly)" images): '
              + ' · '.join(_tool_names[k] + ' ' + str(v) for k, v in sorted(_tools.items()) if k in _tool_names))
          for _d, _p in sorted(_imgs.items(), reverse=True):
            _stack = [('Python', _p.get('python')), ('TensorFlow', _p.get('tensorflow')),
                      ('Keras', _p.get('keras')), ('PyTorch', _p.get('pytorch')),
                      ('CUDA', _p.get('cuda')), ('Ubuntu', _p.get('ubuntu')),
                      ('MATLAB', _pins.get('matlab'))]
            _img_date = _dt.datetime.strptime(_d, '%Y%m%d').strftime('%b %-d, %Y')
            _parts.append('<b>' + _img_date + ' image:</b> '
              + ' · '.join(n + ' ' + str(v) for n, v in _stack if v))
          if _parts:
            _summary = ('<details style="margin-top:6px;"><summary style="cursor:pointer;" class="text-muted">'
              + '<small>What is in these images? (versions as of ' + _built + ')</small></summary>'
              + '<div class="text-muted" style="font-size:0.85em; line-height:1.7; margin:6px 0 0 2px;">'
              + '<br>'.join(_parts)
              + '<br><a href="https://github.com/Queens-School-of-Computing/gpu-jupyter-latest/blob/master/IMAGE-COMPONENTS.md" target="_blank" rel="noopener">Full component list</a>'
              + ' · <a href="https://github.com/Queens-School-of-Computing/gpu-jupyter-latest/blob/master/IMAGE-CHANGELOG.md" target="_blank" rel="noopener">What changed and when</a>'
              + '</div></details>')
            for _k, _v in list(data.items()):
              if _k.startswith('from_data_') and isinstance(_v, str) and '<small id="imageHelp"' in _v:
                data[_k] = _v.replace('<small id="imageHelp"', _summary + '<small id="imageHelp"', 1)
        except Exception:
          pass

        # Inject current MIG partitioning state for the lobot_blackwell form,
        # so the fragment JS (migRenderGpuOptions_lobot_blackwell in
        # generate_html.py) can preselect the node's current mode and warn
        # if the node is currently busy (a GPU pod is running on it).
        # Fail-soft: form still renders (defaulting to the mig_profile
        # marked `default: true` in labs.yaml) if the k8s API is unreachable.
        try:
          from kubernetes_asyncio import client as _k8s_client, config as _k8s_config
          try:
            _k8s_config.load_incluster_config()
          except Exception:
            await _k8s_config.load_kube_config()
          async with _k8s_client.ApiClient() as _api:
            _core = _k8s_client.CoreV1Api(_api)
            _nodes = await _core.list_node(label_selector=MIG_NODE_LABEL_SELECTOR)
            if _nodes.items:
              _node = _nodes.items[0]
              _node_name = _node.metadata.name
              _cur_profile = (_node.metadata.labels or {}).get('nvidia.com/mig.config', '')
              _cur_state = (_node.metadata.labels or {}).get('nvidia.com/mig.config.state', '')
              _pods = await _core.list_pod_for_all_namespaces(
                field_selector=f'spec.nodeName={_node_name}')
              _busy = False
              for _pod in _pods.items:
                if (_pod.status.phase or '') in ('Succeeded', 'Failed'):
                  continue
                for _c in (_pod.spec.containers or []):
                  _req = ((_c.resources and _c.resources.requests) or {})
                  if int(_req.get('nvidia.com/gpu', 0) or 0) > 0:
                    _busy = True
                    break
                if _busy:
                  break
              import json as _json2
              _mig_state_js = ('<script>window.migCurrentProfile=' + _json2.dumps(_cur_profile)
                + ';window.migCurrentState=' + _json2.dumps(_cur_state)
                + ';window.migNodeBusy=' + _json2.dumps(_busy) + ';</script>')
              _k = f'from_data_{MIG_LAB}'
              if isinstance(data.get(_k), str) and 'id="inputMIG"' in data[_k]:
                data[_k] = data[_k].replace('id="inputMIG"', _mig_state_js + 'id="inputMIG"', 1)
        except Exception as _e:
          self.log.warning(f'[dynamic_form] Could not fetch MIG node state: {_e}')

        username = self.user.name.strip().lower()
        self.log.info(username)

        nodeaccess = data.get('nodeaccess', {})
        lab_groups = data.get('lab_groups', {})
        superusers = [u.strip().lower() for u in (data.get('superusers') or [])]

        # Priority-ordered list of (lab_key, storage_class, display_name)
        LAB_META = [
          ('mulab',              'mulab-socsharedstorage',              'MULab Compute Resources'),
          ('bamlab',             'bamlab-socsharedstorage',             'BAMLab Compute Resources (A100 80G)'),
          ('riselab',            'riselab-socsharedstorage',            'RISE Lab Compute Resources'),
          ('lobot_a16',          'lobot_a16-socsharedstorage',          'Lobot Compute Resources (NVIDIA A16 GPU 16GB)'),
          ('digilab',            'digilab-socsharedstorage',            'Lobot Compute Resources (NVIDIA A16 GPU 16GB x4TS)'),
          ('lobot_blackwell',    'lobot_blackwell-socsharedstorage',    'Lobot Compute Resources (NVIDIA Blackwell 48G MIG)'),
          ('lobot_problackwell', 'lobot_problackwell-socsharedstorage', 'Lobot Compute Resources (NVIDIA Pro Blackwell GPU 96GB)'),
          ('quarrglab',          'quarrglab-socsharedstorage',          'QUARRG Lab Compute Resources'),
          ('devlab',             'devlab-socsharedstorage',             'DEV Compute Resources'),
          ('edemsmithbusiness',  'edemsmithbusiness-socsharedstorage',  'Smith School of Business Compute Resources'),
          ('miblab',             'miblab-socsharedstorage',             'MIB Lab Compute Resources'),
          ('winemocollab',       'winemocollab-socsharedstorage',       'WineMocol Lab Compute Resources'),
          ('gandslab',           'gandslab-socsharedstorage',           'GOAL & SWIMS Labs Compute Resources'),
          ('lobot_a40',          'lobot_a40-socsharedstorage',          'Lobot Compute Resources (NVIDIA A40 GPU 48G)'),
          ('lobot_a5000',        'lobot_a5000-socsharedstorage',        'Lobot Compute Resources (NVIDIA A5000 GPU 24G)'),
          ('lobot_cse2026',        'lobot_cse2026-socsharedstorage',    'Lobot Compute Resources for CSE2026'),
        ]
        lab_ss = {lab: ss for lab, ss, _ in LAB_META}
        lab_ds = {lab: ds for lab, _, ds in LAB_META}

        # Superusers get all labs
        if username in superusers:
          accessible_labs = [lab for lab, _, _ in LAB_META]
        else:
          # Find primary lab (first nodeaccess match in priority order)
          primary_lab = None
          for lab, ss, ds in LAB_META:
            if username in [u.strip().lower() for u in (nodeaccess.get(lab) or [])]:
              primary_lab = lab
              break

          # Default fallback
          if primary_lab is None:
            return data['from_data_lobot_a16'].format(
              'lobot_a16-socsharedstorage', 'Lobot Default Compute Resources (NVIDIA A16 GPU 16G)')

          # Expand via lab_groups to get all accessible labs for this user
          accessible_labs = lab_groups.get(primary_lab, [primary_lab])

        # Single lab — existing single-form behavior
        if len(accessible_labs) == 1:
          return data[f'from_data_{primary_lab}'].format(
            lab_ss[primary_lab], lab_ds[primary_lab])

        # --- Multi-lab: build pool-selector form ---
        def make_section(lab, is_first):
          ss = lab_ss.get(lab, f'{lab}-socsharedstorage')
          ds = lab_ds.get(lab, lab)
          html = data.get(f'from_data_{lab}', '').format(ss, ds)
          # Remove per-lab <script> and status div; the switcher provides a shared one
          html = re.sub(r'\s*<script\b[^>]*>.*?</script>', '', html, flags=re.DOTALL)
          html = re.sub(r'\s*<div[^>]+id="label-usage"[^>]*>.*?</div>', '', html, flags=re.DOTALL)
          if not is_first:
            # Disable selects in hidden sections so they are not submitted
            html = re.sub(r'(<select\b)', r'\1 disabled', html)
          display = '' if is_first else ' style="display:none"'
          return f'<div id="lab-form-{lab}" class="lab-form-section"{display}>\n{html}\n</div>\n'

        accessible_labs = sorted(accessible_labs, key=lambda l: lab_ds.get(l, l))
        sections = ''.join(make_section(lab, i == 0) for i, lab in enumerate(accessible_labs))
        pool_options = ''.join(
          f'<option value="{lab}">{lab_ds.get(lab, lab)}</option>\n'
          for lab in accessible_labs
        )
        first_lab = accessible_labs[0]

        return f'''      <script>
      function switchLab(labName) {{
        document.querySelectorAll('.lab-form-section').forEach(function(el) {{
          el.style.display = 'none';
          el.querySelectorAll('select').forEach(function(s) {{ s.disabled = true; }});
        }});
        var section = document.getElementById('lab-form-' + labName);
        section.style.display = '';
        section.querySelectorAll('select').forEach(function(s) {{ s.disabled = false; }});
        $('#label-usage').find('.lab-usage-entry').remove();
        $('#label-summary').text('');
        $('#label-summary-details').text('');
        $.getJSON('https://' + window.location.hostname + '/allocationstatus/current.json', function(d) {{
          if (d && d[labName]) {{
            $('#label-summary').text(d[labName].summary_title);
            $('#label-summary-details').text(d[labName].summary_details);
            $.each(d[labName].usage, function(i, v) {{
              $('#label-usage').append($('<small>').text(v).addClass('form-text text-muted lab-usage-entry')).append($('<br>').addClass('lab-usage-entry'));
            }});
          }}
        }});
      }}
      </script>
      <div class="form-group">
        <label for="lab_selector">Resource Pool</label>
        <select id="lab_selector" class="form-control" onchange="switchLab(this.value)">
          {pool_options}
        </select>
      </div>
      <div class="form-group" id="label-usage">
        <label id="label-summary"></label><br>
        <label id="label-summary-details"></label><br>
      </div>
      {sections}      <script>switchLab('{first_lab}');</script>'''
      #c.Spawner.start_timeout = 420 
      #c.Spawner.start_timeout = 3600 
      c.KubeSpawner.pod_security_context = {'fsGroup': 100,'fsGroupChangePolicy': "OnRootMismatch"}
      c.Spawner.options_form = dynamic_form
      KubeSpawner.options_from_form = options_from_form
    pre_spawn_hook: |
      # Duplicated from custom_options_form (extraConfig blocks don't share
      # Python state). Keep in sync with the gpu-operator mig-config
      # ConfigMap and assets/labs.yaml mig_profiles.
      MIG_PROFILES = {
        'all-disabled':    1,
        'all-1g.24gb':     4,
        'all-1g.24gb+gfx': 4,
        'all-1g.24gb+me':  1,
        'all-2g.48gb':     2,
        'all-2g.48gb+gfx': 2,
      }
      MIG_LAB = 'lobot_blackwell'
      MIG_NODE_LABEL_SELECTOR = 'lab=lobot_blackwell'
      MIG_GPU_COUNT = 6
      MIG_STATE_POLL_TIMEOUT = 180   # seconds to wait for mig.config.state == success
      MIG_STATE_POLL_INTERVAL = 5

      async def my_pre_spawn_hook(spwnr):
        import os, urllib.request, yaml, smtplib, asyncio
        from tornado.web import HTTPError
        from email.mime.text import MIMEText

        class SpawnError(HTTPError):
          def __init__(self, message):
            super().__init__(400, message)
            self.jupyterhub_message = message

        async def _ensure_mig_profile(target_profile):
          """Repartition the lobot_blackwell node to target_profile if it
          isn't already there. Blocks (raises SpawnError) if any pod on the
          node currently has an active GPU request. Best-effort: any
          unexpected k8s error surfaces as a SpawnError rather than silently
          proceeding, since a wrong partition size would misallocate GPUs."""
          from kubernetes_asyncio import client as _k8s_client, config as _k8s_config
          try:
            _k8s_config.load_incluster_config()
          except Exception:
            await _k8s_config.load_kube_config()
          async with _k8s_client.ApiClient() as _api:
            _core = _k8s_client.CoreV1Api(_api)
            _nodes = await _core.list_node(label_selector=MIG_NODE_LABEL_SELECTOR)
            if not _nodes.items:
              raise SpawnError('Could not find the GPU node for this lab. Please contact help@cs.queensu.ca.')
            _node = _nodes.items[0]
            _node_name = _node.metadata.name
            _cur_profile = (_node.metadata.labels or {}).get('nvidia.com/mig.config', '')

            if _cur_profile == target_profile:
              return  # already in the desired mode, nothing to do

            # Block if any pod on the node has an active GPU request.
            _pods = await _core.list_pod_for_all_namespaces(
              field_selector=f'spec.nodeName={_node_name}')
            for _pod in _pods.items:
              if (_pod.status.phase or '') in ('Succeeded', 'Failed'):
                continue
              for _c in (_pod.spec.containers or []):
                _req = ((_c.resources and _c.resources.requests) or {})
                if int(_req.get('nvidia.com/gpu', 0) or 0) > 0:
                  raise SpawnError(
                    'GPU repartitioning blocked — another session on this node is '
                    'currently using a GPU. Wait for it to finish, or spawn with the '
                    'current partitioning mode instead.')

            async def _patch_and_wait(profile):
              await _core.patch_node(_node_name, {'metadata': {'labels': {'nvidia.com/mig.config': profile}}})
              _elapsed = 0
              while _elapsed < MIG_STATE_POLL_TIMEOUT:
                await asyncio.sleep(MIG_STATE_POLL_INTERVAL)
                _elapsed += MIG_STATE_POLL_INTERVAL
                _n = await _core.read_node(_node_name)
                _state = (_n.metadata.labels or {}).get('nvidia.com/mig.config.state', '')
                if _state == 'success':
                  return True
                if _state == 'failed':
                  return False
              return False  # timed out

            spwnr.log.info(f'[pre_spawn_hook] Repartitioning {_node_name}: {_cur_profile!r} -> {target_profile!r}')
            _ok = await _patch_and_wait(target_profile)
            if not _ok:
              # Bounce the label once and retry — mig.config.state is not
              # self-healing on failure (see lobot_gpu_timeslicing_mig.md).
              spwnr.log.warning(f'[pre_spawn_hook] MIG repartition to {target_profile!r} did not succeed; retrying once')
              _ok = await _patch_and_wait(target_profile)
            if not _ok:
              raise SpawnError(
                f'GPU repartitioning to "{target_profile}" failed or timed out. '
                'The node may need manual attention — please contact help@cs.queensu.ca.')

        def _send_violation_email(subject, body):
          try:
            msg = MIMEText(body)
            msg['Subject'] = subject
            msg['From'] = 'lobot@cs.queensu.ca'
            msg['To'] = 'aaron@cs.queensu.ca'
            with smtplib.SMTP('innovate.cs.queensu.ca', 25, timeout=5) as s:
              s.sendmail('lobot@cs.queensu.ca', ['aaron@cs.queensu.ca'], msg.as_string())
          except Exception as _e:
            spwnr.log.warning(f'[pre_spawn_hook] Failed to send violation email: {_e}')

        RUNTIME_URL = os.environ.get("LOBOT_RUNTIME_URL", "https://raw.githubusercontent.com/Queens-School-of-Computing/Lobot/main/runtime_setting.yaml")
        if spwnr.user.name in _COLLAB_USERS:
          spwnr.log.info(f"(DISABLED) Enabling RTC for collaboration user {spwnr.user.name}")
          #AV Feb 17 2026 - don't need specific RTC flags. Images are updated to support it.
          #c.ServerApp.collaborative = True
        username = spwnr.user.name.strip().lower()
        spwnr.log.info('username:' + username)
        spwnr.log.info('  spwnr.user_options: ' + str(spwnr.user_options))
        options = spwnr.user_options
        lab = options['storage_class'][0].split('-')[0]

        # --- Server-side validation (all users) ---
        try:
          data = yaml.safe_load(urllib.request.urlopen(RUNTIME_URL, timeout=5).read().decode('utf-8')) or {}
        except Exception as e:
          spwnr.log.error(f'[pre_spawn_hook] Failed to load runtime settings: {e}')
          raise SpawnError('Could not validate resource request. Please try again.')

        # 1. Validate user has access to the submitted lab (prevents lab-switching)
        nodeaccess = data.get('nodeaccess', {})
        lab_groups = data.get('lab_groups', {})
        superusers = [u.strip().lower() for u in (data.get('superusers') or [])]
        lab_users = [u.strip().lower() for u in (nodeaccess.get(lab) or [])]
        if username not in lab_users and username not in superusers:
          # Also allow access if user is in a primary lab whose lab_groups includes this lab
          has_group_access = any(
            lab in group_labs and username in [u.strip().lower() for u in (nodeaccess.get(primary) or [])]
            for primary, group_labs in lab_groups.items()
          )
          if not has_group_access:
            spwnr.log.warning(f'[pre_spawn_hook] SECURITY: {username} attempted unauthorized access to lab {lab}')
            _send_violation_email(
              f'[Lobot] Policy Violation: Unauthorized lab access by {username}',
              f'GitHub user: {username}\nAttempted lab: {lab}\nAction: unauthorized lab access\n'
            )
            raise SpawnError(f'POLICY VIOLATION: You do not have access to {lab}. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

        # 2. Validate resource limits against runtime_setting.yaml limits section
        limits = (data.get('limits') or {}).get(lab)
        if limits:
          def parse_mem_gb(s):
            s = str(s).upper()
            if s.endswith('G'): return float(s[:-1])
            if s.endswith('M'): return float(s[:-1]) / 1024
            return float(s)

          req_gpu = int(options['gpu_limit'][0])
          if req_gpu < 0: req_gpu = 0
          max_gpu = int(limits.get('max_gpu', 0))
          if req_gpu > max_gpu:
            spwnr.log.warning(f'[pre_spawn_hook] SECURITY: {username} requested {req_gpu} GPUs, max={max_gpu}')
            _send_violation_email(
              f'[Lobot] Policy Violation: GPU limit exceeded by {username} on {lab}',
              f'GitHub user: {username}\nLab: {lab}\nRequested: {req_gpu} GPU(s)\nLimit: {max_gpu} GPU(s)\n'
            )
            raise SpawnError(f'POLICY VIOLATION: Requested {req_gpu} GPU(s) exceeds your allocated limit of {max_gpu}. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

          req_cpu = float(options['cpu_limit'][0])
          max_cpu = float(limits.get('max_cpu', 0))
          if max_cpu > 0 and req_cpu > max_cpu:
            spwnr.log.warning(f'[pre_spawn_hook] SECURITY: {username} requested {req_cpu} CPUs, max={max_cpu}')
            _send_violation_email(
              f'[Lobot] Policy Violation: CPU limit exceeded by {username} on {lab}',
              f'GitHub user: {username}\nLab: {lab}\nRequested: {req_cpu} CPU cores\nLimit: {max_cpu} CPU cores\n'
            )
            raise SpawnError(f'POLICY VIOLATION: Requested {req_cpu} CPU cores exceeds your allocated limit of {max_cpu}. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

          req_mem_gb = parse_mem_gb(options['mem_limit'][0])
          max_mem_gb = float(limits.get('max_mem_gb', 0))
          if max_mem_gb > 0 and req_mem_gb > max_mem_gb:
            spwnr.log.warning(f'[pre_spawn_hook] SECURITY: {username} requested {req_mem_gb}G memory, max={max_mem_gb}G')
            _send_violation_email(
              f'[Lobot] Policy Violation: Memory limit exceeded by {username} on {lab}',
              f'GitHub user: {username}\nLab: {lab}\nRequested: {req_mem_gb}G\nLimit: {max_mem_gb}G\n'
            )
            raise SpawnError(f'POLICY VIOLATION: Requested {req_mem_gb}G memory exceeds your allocated limit of {max_mem_gb}G. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

        # 3. Validate image against allowed options for this lab
        import re as _re
        _lab_html = (data.get(f'from_data_{lab}') or '')
        _img_select = _re.search(
          r'<select[^>]+name=["\']image["\'][^>]*>(.*?)</select>',
          _lab_html, flags=_re.DOTALL)
        if _img_select:
          _allowed_images = _re.findall(r'<option[^>]+value=["\']([^"\']*)["\']', _img_select.group(1))
          req_image = options['image'][0]
          if _allowed_images and req_image not in _allowed_images:
            spwnr.log.warning(f'[pre_spawn_hook] SECURITY: {username} attempted unauthorized image {req_image!r}')
            _send_violation_email(
              f'[Lobot] Policy Violation: Unauthorized image by {username} on {lab}',
              f'GitHub user: {username}\nLab: {lab}\nAttempted image: {req_image}\nAllowed images: {", ".join(_allowed_images)}\n'
            )
            raise SpawnError(f'POLICY VIOLATION: Image "{req_image}" is not permitted on this system. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')
        # --- End validation ---

        spwnr.image = options['image'][0]
        #spwnr.cpu_limit = float(options['cpu_limit'][0])
        #spwnr.cpu_limit = options['cpu_limit'][0]
        # Never set CPU Limit, only request, and memoryrequest=memorylimit https://home.robusta.dev/blog/kubernetes-memory-limit
        spwnr.cpu_limit = None
        spwnr.cpu_guarantee = float(options['cpu_limit'][0])
        spwnr.mem_limit = options['mem_limit'][0]
        spwnr.mem_guarantee = options['mem_limit'][0]
        sctype = options['storage_class'][0].split('-')[1]
        spwnr.storage_class = options['storage_class'][0]
        if sctype == 'socsharedstorage':
          spwnr.log.info('  socsharedstorage with ' + str(lab))
          spwnr.storage_class = str('caslab-retain-r1')
        
        #if lab in ('bamlab'):
        if lab in ('bamlab', 'lobot_blackwell'):    #commented out to fix up RWO with other shared volumes.
          spwnr.volumes.extend([
                 {
                         "name": "pv-bamlabshareddata",
                         "persistentVolumeClaim": {"claimName": "pvc-bamlabshareddata"}
                 },
                 {
                         "name": "pvc-6cefcf15-7c4f-4034-9e93-712fff961490",
                         "persistentVolumeClaim": {"claimName": "claim-21at45"}
                 }
          ])
          spwnr.volume_mounts.extend([
                 {
                         "mountPath": "/home/jovyan/bamlabshareddata",
                         "name": "pv-bamlabshareddata"
                 },
                 {
                         "mountPath": "/home/jovyan/bamlab_archive_alanteng",
                         "name": "pvc-6cefcf15-7c4f-4034-9e93-712fff961490"
                 }
          ])
          if username in ('nafiz95', 'wiegerthefarmer'):
            spwnr.volumes.extend([
                   {"name": "pv-bamlab-ildpatients", "persistentVolumeClaim": {"claimName": "pvc-bamlab-ildpatients"}},
                   {"name": "nfs-nafiz25tb", "hostPath": {"path": "/mnt/nafiz25TB"}}, 
            ])
            spwnr.volume_mounts.extend([
                   {"mountPath": "/home/jovyan/bamlab_ildpatients", "name": "pv-bamlab-ildpatients"},
                   {"mountPath": "/home/jovyan/nafiz25TB", "name": "nfs-nafiz25tb"},  
            ])
        req_gpu_slices = int(options["gpu_limit"][0])
        if lab == MIG_LAB and 'mig_profile' in options and req_gpu_slices > 0:
          mig_profile = options['mig_profile'][0]
          if mig_profile not in MIG_PROFILES:
            raise SpawnError(f'POLICY VIOLATION: "{mig_profile}" is not a recognized GPU partitioning mode.')
          max_slices = MIG_PROFILES[mig_profile] * MIG_GPU_COUNT
          if req_gpu_slices > max_slices:
            spwnr.log.warning(f'[pre_spawn_hook] SECURITY: {username} requested {req_gpu_slices} MIG slices, max={max_slices} for mode {mig_profile}')
            raise SpawnError(f'POLICY VIOLATION: Requested {req_gpu_slices} GPU slice(s) exceeds the maximum of {max_slices} for MIG mode "{mig_profile}". Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')
          await _ensure_mig_profile(mig_profile)

        spwnr.extra_resource_limits = {"nvidia.com/gpu": req_gpu_slices}
        if req_gpu_slices == 0:
          spwnr.environment = {'NVIDIA_VISIBLE_DEVICES':'none'}
        if req_gpu_slices == -1:
          spwnr.extra_resource_limits = {"nvidia.com/gpu": 0}
        spwnr.node_selector = {'lab': lab}
        spwnr.log.info('  spawner: ' + str(spwnr))
      c.Spawner.pre_spawn_hook = my_pre_spawn_hook
      c.KubeSpawner.pod_security_context = {'fsGroup': 100,'fsGroupChangePolicy': "OnRootMismatch"}
      c.KubeSpawner.pod_security_context.update({'fsGroupChangePolicy': 'OnRootMismatch'})