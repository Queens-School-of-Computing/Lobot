    custom_options_form: |
      from kubespawner import KubeSpawner

      def options_from_form(self, formdata):
        import urllib.request, yaml, os, re as _re, smtplib
        from email.mime.text import MIMEText

        username = self.user.name.strip().lower()

        def _send_violation_email(subject, body):
          try:
            msg = MIMEText(body)
            msg['Subject'] = subject
            msg['From'] = 'lobot@cs.queensu.ca'
            msg['To'] = 'aaron@cs.queensu.ca'
            with smtplib.SMTP('innovate.cs.queensu.ca', 25, timeout=5) as s:
              s.sendmail('lobot@cs.queensu.ca', ['aaron@cs.queensu.ca'], msg.as_string())
          except Exception:
            pass

        options = {}
        options['image'] = formdata['image']
        options['cpu_limit'] = formdata['cpu_limit']
        options['mem_limit'] = formdata['mem_limit']
        options['gpu_limit'] = formdata['gpu_limit']
        options['storage_class'] = formdata['storage_class']

        # All validation runs before spawn-pending so errors show on the spawn form.
        # If the YAML fetch fails, silently pass — pre_spawn_hook will re-validate.
        lab = options['storage_class'][0].split('-')[0]
        RUNTIME_URL = os.environ.get("LOBOT_RUNTIME_URL", "https://raw.githubusercontent.com/Queens-School-of-Computing/Lobot/main/runtime_setting.yaml")
        try:
          data = yaml.safe_load(urllib.request.urlopen(RUNTIME_URL, timeout=5).read().decode('utf-8')) or {}

          # Validate image against allowed options for this lab
          lab_html = (data.get(f'from_data_{lab}') or '')
          _img_select = _re.search(
            r'<select[^>]+name=["\']image["\'][^>]*>(.*?)</select>',
            lab_html, flags=_re.DOTALL)
          if _img_select:
            _allowed_images = _re.findall(r'<option[^>]+value=["\']([^"\']*)["\']', _img_select.group(1))
            req_image = options['image'][0]
            if _allowed_images and req_image not in _allowed_images:
              _send_violation_email(
                f'[Lobot] Policy Violation: Unauthorized image by {username} on {lab}',
                f'GitHub user:     {username}\n'
                f'Lab:             {lab}\n'
                f'Attempted image: {req_image}\n'
                f'Allowed images:  {", ".join(_allowed_images)}\n'
              )
              raise ValueError(f'POLICY VIOLATION: Image "{req_image}" is not permitted on this system. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

          # Validate resource limits
          limits = (data.get('limits') or {}).get(lab)
          if limits:
            def parse_mem_gb(s):
              s = str(s).upper()
              if s.endswith('G'): return float(s[:-1])
              if s.endswith('M'): return float(s[:-1]) / 1024
              return float(s)

            req_gpu = int(options['gpu_limit'][0])
            if req_gpu < 0: req_gpu = 0
            max_gpu = int(limits.get('max_gpu', 0))
            if req_gpu > max_gpu:
              _send_violation_email(
                f'[Lobot] Policy Violation: GPU limit exceeded by {username} on {lab}',
                f'GitHub user: {username}\n'
                f'Lab:         {lab}\n'
                f'Requested:   {req_gpu} GPU(s)\n'
                f'Limit:       {max_gpu} GPU(s)\n'
              )
              raise ValueError(f'POLICY VIOLATION: Requested {req_gpu} GPU(s) exceeds your allocated limit of {max_gpu}. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

            req_cpu = float(options['cpu_limit'][0])
            max_cpu = float(limits.get('max_cpu', 0))
            if max_cpu > 0 and req_cpu > max_cpu:
              _send_violation_email(
                f'[Lobot] Policy Violation: CPU limit exceeded by {username} on {lab}',
                f'GitHub user: {username}\n'
                f'Lab:         {lab}\n'
                f'Requested:   {req_cpu} CPU cores\n'
                f'Limit:       {max_cpu} CPU cores\n'
              )
              raise ValueError(f'POLICY VIOLATION: Requested {req_cpu} CPU cores exceeds your allocated limit of {max_cpu}. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

            req_mem_gb = parse_mem_gb(options['mem_limit'][0])
            max_mem_gb = float(limits.get('max_mem_gb', 0))
            if max_mem_gb > 0 and req_mem_gb > max_mem_gb:
              _send_violation_email(
                f'[Lobot] Policy Violation: Memory limit exceeded by {username} on {lab}',
                f'GitHub user: {username}\n'
                f'Lab:         {lab}\n'
                f'Requested:   {req_mem_gb}G\n'
                f'Limit:       {max_mem_gb}G\n'
              )
              raise ValueError(f'POLICY VIOLATION: Requested {req_mem_gb}G memory exceeds your allocated limit of {max_mem_gb}G. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

        except ValueError:
          raise
        except Exception:
          pass  # Don't block spawn if YAML fetch fails; pre_spawn_hook will re-validate

        return options
      async def dynamic_form(self):
        import urllib.request, yaml, os, re

        data = yaml.safe_load(urllib.request.urlopen(
          os.environ.get("LOBOT_RUNTIME_URL",
            "https://raw.githubusercontent.com/Queens-School-of-Computing/Lobot/main/runtime_setting.yaml")
        ).read().decode('utf-8'))
        self.log.info(str(data))
        username = self.user.name.strip().lower()
        self.log.info(username)

        nodeaccess = data.get('nodeaccess', {})
        lab_groups = data.get('lab_groups', {})
        superusers = [u.strip().lower() for u in (data.get('superusers') or [])]

        # Priority-ordered list of (lab_key, storage_class, display_name)
        LAB_META = [
          ('mulab',              'mulab-socsharedstorage',              'MULab Compute Resources'),
          ('bamlab',             'bamlab-socsharedstorage',             'BAMLab Compute Resources (A100 80G)'),
          ('riselab',            'riselab-socsharedstorage',            'RISE Lab Compute Resources'),
          ('lobot_a16',          'lobot_a16-socsharedstorage',          'Lobot Compute Resources (NVIDIA A16 GPU 16GB)'),
          ('digilab',            'digilab-socsharedstorage',            'Digilians Compute Resources'),
          ('lobot_blackwell',    'lobot_blackwell-socsharedstorage',    'Lobot Compute Resources (NVIDIA Blackwell 48G MIG)'),
          ('lobot_problackwell', 'lobot_problackwell-socsharedstorage', 'Lobot Compute Resources (NVIDIA Pro Blackwell GPU 96GB)'),
          ('quarrglab',          'quarrglab-socsharedstorage',          'QUARRG Lab Compute Resources'),
          ('devlab',             'devlab-socsharedstorage',             'DEV Compute Resources'),
          ('edemsmithbusiness',  'edemsmithbusiness-socsharedstorage',  'Smith School of Business Compute Resources'),
          ('miblab',             'miblab-socsharedstorage',             'MIB Lab Compute Resources'),
          ('winemocollab',       'winemocollab-socsharedstorage',       'WineMocol Lab Compute Resources'),
          ('gandslab',           'gandslab-socsharedstorage',           'GAIN & SWIMS Labs Compute Resources'),
          ('lobot_a40',          'lobot_a40-socsharedstorage',          'Lobot Compute Resources (NVIDIA A40 GPU 48G)'),
          ('lobot_a5000',        'lobot_a5000-socsharedstorage',        'Lobot Compute Resources (NVIDIA A5000 GPU 24G)'),
        ]
        lab_ss = {lab: ss for lab, ss, _ in LAB_META}
        lab_ds = {lab: ds for lab, _, ds in LAB_META}

        # Superusers get all labs
        if username in superusers:
          accessible_labs = [lab for lab, _, _ in LAB_META]
        else:
          # Find primary lab (first nodeaccess match in priority order)
          primary_lab = None
          for lab, ss, ds in LAB_META:
            if username in [u.strip().lower() for u in (nodeaccess.get(lab) or [])]:
              primary_lab = lab
              break

          # Default fallback
          if primary_lab is None:
            return data['from_data_lobot_a16'].format(
              'lobot_a16-socsharedstorage', 'Lobot Default Compute Resources (NVIDIA A16 GPU 16G)')

          # Expand via lab_groups to get all accessible labs for this user
          accessible_labs = lab_groups.get(primary_lab, [primary_lab])

        # Single lab — existing single-form behavior
        if len(accessible_labs) == 1:
          return data[f'from_data_{primary_lab}'].format(
            lab_ss[primary_lab], lab_ds[primary_lab])

        # --- Multi-lab: build pool-selector form ---
        def make_section(lab, is_first):
          ss = lab_ss.get(lab, f'{lab}-socsharedstorage')
          ds = lab_ds.get(lab, lab)
          html = data.get(f'from_data_{lab}', '').format(ss, ds)
          # Remove per-lab <script> and status div; the switcher provides a shared one
          html = re.sub(r'\s*<script\b[^>]*>.*?</script>', '', html, flags=re.DOTALL)
          html = re.sub(r'\s*<div[^>]+id="label-usage"[^>]*>.*?</div>', '', html, flags=re.DOTALL)
          if not is_first:
            # Disable selects in hidden sections so they are not submitted
            html = re.sub(r'(<select\b)', r'\1 disabled', html)
          display = '' if is_first else ' style="display:none"'
          return f'<div id="lab-form-{lab}" class="lab-form-section"{display}>\n{html}\n</div>\n'

        accessible_labs = sorted(accessible_labs, key=lambda l: lab_ds.get(l, l))
        sections = ''.join(make_section(lab, i == 0) for i, lab in enumerate(accessible_labs))
        pool_options = ''.join(
          f'<option value="{lab}">{lab_ds.get(lab, lab)}</option>\n'
          for lab in accessible_labs
        )
        first_lab = accessible_labs[0]

        return f'''      <script>
      function switchLab(labName) {{
        document.querySelectorAll('.lab-form-section').forEach(function(el) {{
          el.style.display = 'none';
          el.querySelectorAll('select').forEach(function(s) {{ s.disabled = true; }});
        }});
        var section = document.getElementById('lab-form-' + labName);
        section.style.display = '';
        section.querySelectorAll('select').forEach(function(s) {{ s.disabled = false; }});
        $('#label-usage').find('.lab-usage-entry').remove();
        $('#label-summary').text('');
        $('#label-summary-details').text('');
        $.getJSON('https://' + window.location.hostname + '/allocationstatus/current.json', function(d) {{
          if (d && d[labName]) {{
            $('#label-summary').text(d[labName].summary_title);
            $('#label-summary-details').text(d[labName].summary_details);
            $.each(d[labName].usage, function(i, v) {{
              $('#label-usage').append($('<small>').text(v).addClass('form-text text-muted lab-usage-entry')).append($('<br>').addClass('lab-usage-entry'));
            }});
          }}
        }});
      }}
      </script>
      <div class="form-group">
        <label for="lab_selector">Resource Pool</label>
        <select id="lab_selector" class="form-control" onchange="switchLab(this.value)">
          {pool_options}
        </select>
      </div>
      <div class="form-group" id="label-usage">
        <label id="label-summary"></label><br>
        <label id="label-summary-details"></label><br>
      </div>
      {sections}      <script>switchLab('{first_lab}');</script>'''
      #c.Spawner.start_timeout = 420 
      #c.Spawner.start_timeout = 3600 
      c.KubeSpawner.pod_security_context = {'fsGroup': 100,'fsGroupChangePolicy': "OnRootMismatch"}
      c.Spawner.options_form = dynamic_form
      KubeSpawner.options_from_form = options_from_form
    pre_spawn_hook: |
      async def my_pre_spawn_hook(spwnr):
        import os, urllib.request, yaml, smtplib
        from tornado.web import HTTPError
        from email.mime.text import MIMEText

        class SpawnError(HTTPError):
          def __init__(self, message):
            super().__init__(400, message)
            self.jupyterhub_message = message

        def _send_violation_email(subject, body):
          try:
            msg = MIMEText(body)
            msg['Subject'] = subject
            msg['From'] = 'lobot@cs.queensu.ca'
            msg['To'] = 'aaron@cs.queensu.ca'
            with smtplib.SMTP('innovate.cs.queensu.ca', 25, timeout=5) as s:
              s.sendmail('lobot@cs.queensu.ca', ['aaron@cs.queensu.ca'], msg.as_string())
          except Exception as _e:
            spwnr.log.warning(f'[pre_spawn_hook] Failed to send violation email: {_e}')

        RUNTIME_URL = os.environ.get("LOBOT_RUNTIME_URL", "https://raw.githubusercontent.com/Queens-School-of-Computing/Lobot/main/runtime_setting.yaml")
        if spwnr.user.name in _COLLAB_USERS:
          spwnr.log.info(f"(DISABLED) Enabling RTC for collaboration user {spwnr.user.name}")
          #AV Feb 17 2026 - don't need specific RTC flags. Images are updated to support it.
          #c.ServerApp.collaborative = True
        username = spwnr.user.name.strip().lower()
        spwnr.log.info('username:' + username)
        spwnr.log.info('  spwnr.user_options: ' + str(spwnr.user_options))
        options = spwnr.user_options
        lab = options['storage_class'][0].split('-')[0]

        # --- Server-side validation (all users) ---
        try:
          data = yaml.safe_load(urllib.request.urlopen(RUNTIME_URL, timeout=5).read().decode('utf-8')) or {}
        except Exception as e:
          spwnr.log.error(f'[pre_spawn_hook] Failed to load runtime settings: {e}')
          raise SpawnError('Could not validate resource request. Please try again.')

        # 1. Validate user has access to the submitted lab (prevents lab-switching)
        nodeaccess = data.get('nodeaccess', {})
        lab_groups = data.get('lab_groups', {})
        superusers = [u.strip().lower() for u in (data.get('superusers') or [])]
        lab_users = [u.strip().lower() for u in (nodeaccess.get(lab) or [])]
        if username not in lab_users and username not in superusers:
          # Also allow access if user is in a primary lab whose lab_groups includes this lab
          has_group_access = any(
            lab in group_labs and username in [u.strip().lower() for u in (nodeaccess.get(primary) or [])]
            for primary, group_labs in lab_groups.items()
          )
          if not has_group_access:
            spwnr.log.warning(f'[pre_spawn_hook] SECURITY: {username} attempted unauthorized access to lab {lab}')
            _send_violation_email(
              f'[Lobot] Policy Violation: Unauthorized lab access by {username}',
              f'GitHub user: {username}\nAttempted lab: {lab}\nAction: unauthorized lab access\n'
            )
            raise SpawnError(f'POLICY VIOLATION: You do not have access to {lab}. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

        # 2. Validate resource limits against runtime_setting.yaml limits section
        limits = (data.get('limits') or {}).get(lab)
        if limits:
          def parse_mem_gb(s):
            s = str(s).upper()
            if s.endswith('G'): return float(s[:-1])
            if s.endswith('M'): return float(s[:-1]) / 1024
            return float(s)

          req_gpu = int(options['gpu_limit'][0])
          if req_gpu < 0: req_gpu = 0
          max_gpu = int(limits.get('max_gpu', 0))
          if req_gpu > max_gpu:
            spwnr.log.warning(f'[pre_spawn_hook] SECURITY: {username} requested {req_gpu} GPUs, max={max_gpu}')
            _send_violation_email(
              f'[Lobot] Policy Violation: GPU limit exceeded by {username} on {lab}',
              f'GitHub user: {username}\nLab: {lab}\nRequested: {req_gpu} GPU(s)\nLimit: {max_gpu} GPU(s)\n'
            )
            raise SpawnError(f'POLICY VIOLATION: Requested {req_gpu} GPU(s) exceeds your allocated limit of {max_gpu}. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

          req_cpu = float(options['cpu_limit'][0])
          max_cpu = float(limits.get('max_cpu', 0))
          if max_cpu > 0 and req_cpu > max_cpu:
            spwnr.log.warning(f'[pre_spawn_hook] SECURITY: {username} requested {req_cpu} CPUs, max={max_cpu}')
            _send_violation_email(
              f'[Lobot] Policy Violation: CPU limit exceeded by {username} on {lab}',
              f'GitHub user: {username}\nLab: {lab}\nRequested: {req_cpu} CPU cores\nLimit: {max_cpu} CPU cores\n'
            )
            raise SpawnError(f'POLICY VIOLATION: Requested {req_cpu} CPU cores exceeds your allocated limit of {max_cpu}. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

          req_mem_gb = parse_mem_gb(options['mem_limit'][0])
          max_mem_gb = float(limits.get('max_mem_gb', 0))
          if max_mem_gb > 0 and req_mem_gb > max_mem_gb:
            spwnr.log.warning(f'[pre_spawn_hook] SECURITY: {username} requested {req_mem_gb}G memory, max={max_mem_gb}G')
            _send_violation_email(
              f'[Lobot] Policy Violation: Memory limit exceeded by {username} on {lab}',
              f'GitHub user: {username}\nLab: {lab}\nRequested: {req_mem_gb}G\nLimit: {max_mem_gb}G\n'
            )
            raise SpawnError(f'POLICY VIOLATION: Requested {req_mem_gb}G memory exceeds your allocated limit of {max_mem_gb}G. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')

        # 3. Validate image against allowed options for this lab
        import re as _re
        _lab_html = (data.get(f'from_data_{lab}') or '')
        _img_select = _re.search(
          r'<select[^>]+name=["\']image["\'][^>]*>(.*?)</select>',
          _lab_html, flags=_re.DOTALL)
        if _img_select:
          _allowed_images = _re.findall(r'<option[^>]+value=["\']([^"\']*)["\']', _img_select.group(1))
          req_image = options['image'][0]
          if _allowed_images and req_image not in _allowed_images:
            spwnr.log.warning(f'[pre_spawn_hook] SECURITY: {username} attempted unauthorized image {req_image!r}')
            _send_violation_email(
              f'[Lobot] Policy Violation: Unauthorized image by {username} on {lab}',
              f'GitHub user: {username}\nLab: {lab}\nAttempted image: {req_image}\nAllowed images: {", ".join(_allowed_images)}\n'
            )
            raise SpawnError(f'POLICY VIOLATION: Image "{req_image}" is not permitted on this system. Misuse of Lobot is automatically reported to help@cs.queensu.ca and may result in immediate loss of access.')
        # --- End validation ---

        spwnr.image = options['image'][0]
        #spwnr.cpu_limit = float(options['cpu_limit'][0])
        #spwnr.cpu_limit = options['cpu_limit'][0]
        # Never set CPU Limit, only request, and memoryrequest=memorylimit https://home.robusta.dev/blog/kubernetes-memory-limit
        spwnr.cpu_limit = None
        spwnr.cpu_guarantee = float(options['cpu_limit'][0])
        spwnr.mem_limit = options['mem_limit'][0]
        spwnr.mem_guarantee = options['mem_limit'][0]
        sctype = options['storage_class'][0].split('-')[1]
        spwnr.storage_class = options['storage_class'][0]
        if sctype == 'socsharedstorage':
          spwnr.log.info('  socsharedstorage with ' + str(lab))
          spwnr.storage_class = str('caslab-retain-r1')
        
        #if lab in ('bamlab'):
        if lab in ('bamlab', 'lobot_blackwell'):    #commented out to fix up RWO with other shared volumes.
          spwnr.volumes.extend([
                 {
                         "name": "pv-bamlabshareddata",
                         "persistentVolumeClaim": {"claimName": "pvc-bamlabshareddata"}
                 },
                 {
                         "name": "pvc-6cefcf15-7c4f-4034-9e93-712fff961490",
                         "persistentVolumeClaim": {"claimName": "claim-21at45"}
                 }
          ])
          spwnr.volume_mounts.extend([
                 {
                         "mountPath": "/home/jovyan/bamlabshareddata",
                         "name": "pv-bamlabshareddata"
                 },
                 {
                         "mountPath": "/home/jovyan/bamlab_archive_alanteng",
                         "name": "pvc-6cefcf15-7c4f-4034-9e93-712fff961490"
                 }
          ])
          if username in ('nafiz95', 'wiegerthefarmer'):
            spwnr.volumes.extend([
                   {"name": "pv-bamlab-ildpatients", "persistentVolumeClaim": {"claimName": "pvc-bamlab-ildpatients"}},
                   {"name": "nfs-nafiz25tb", "hostPath": {"path": "/mnt/nafiz25TB"}}, 
            ])
            spwnr.volume_mounts.extend([
                   {"mountPath": "/home/jovyan/bamlab_ildpatients", "name": "pv-bamlab-ildpatients"},
                   {"mountPath": "/home/jovyan/nafiz25TB", "name": "nfs-nafiz25tb"},  
            ])
        spwnr.extra_resource_limits = {"nvidia.com/gpu": int(options["gpu_limit"][0])}
        if int(options["gpu_limit"][0]) == 0:
          spwnr.environment = {'NVIDIA_VISIBLE_DEVICES':'none'}
        if int(options["gpu_limit"][0]) == -1:
          spwnr.extra_resource_limits = {"nvidia.com/gpu": 0}
        spwnr.node_selector = {'lab': lab}
        spwnr.log.info('  spawner: ' + str(spwnr))
      c.Spawner.pre_spawn_hook = my_pre_spawn_hook
      c.KubeSpawner.pod_security_context = {'fsGroup': 100,'fsGroupChangePolicy': "OnRootMismatch"}
      c.KubeSpawner.pod_security_context.update({'fsGroupChangePolicy': 'OnRootMismatch'})