      c.JupyterHub.services += [
          {
              "name": "group-manager",
              "api_token": "xxx",  
          }
      ]
    10-group-roles-from-yaml: |
      import os, urllib.request, yaml

      GROUP_ROLES_URL = os.environ.get("LOBOT_GROUP_ROLES_URL", "https://raw.githubusercontent.com/Queens-School-of-Computing/Lobot/main/group-roles.yaml")

      # Global set of collaboration users, based on roles whose name starts with 'group-'
      _COLLAB_USERS = set()

      def _load_group_roles_and_service_role():
          global _COLLAB_USERS
          _COLLAB_USERS = set()

          try:
              raw = urllib.request.urlopen(GROUP_ROLES_URL).read().decode("utf-8")
              data = yaml.safe_load(raw) or {}
          except Exception as e:
              print(f"load_roles: failed to fetch {GROUP_ROLES_URL}: {e}")
              return []

          roles_cfg = data.get("roles", [])
          roles = []

          for r in roles_cfg:
              name = r.get("name")
              owner = r.get("user")
              members = r.get("members", []) or []
              if not (name and owner):
                  continue

              # any role whose name starts with "group-" is treated as a collab role
              if name.startswith("group-"):
                  _COLLAB_USERS.add(owner)

              # default scopes if none specified in YAML, open only, no start or stop
              default_scopes = [
                  f"access:servers!user={owner}",
              ]

              raw_scopes = r.get("scopes")
              if raw_scopes:
                  # substitute {user} with owner in each scope string
                  scopes = [s.format(user=owner) for s in raw_scopes]
              else:
                  scopes = default_scopes

              roles.append(
                  {
                      "name": name,
                      "scopes": scopes,
                      "users": members,
                  }
              )
          
          # Add the group-manager service role here
          roles.append(
              {
                  "name": "group-manager-role",
                  "scopes": [
                      "admin:users", # for adding new local users
                      "admin:groups",# for read/write group and membership
                  ],
                  "services": ["group-manager"],
              }
          )
          print(f"load_roles: feteched these roles in {GROUP_ROLES_URL}: {str(roles)}")
          print(f"collab-users-from-roles: collaboration users = {sorted(_COLLAB_USERS)}")
          return roles

      c.JupyterHub.load_roles += _load_group_roles_and_service_role()
    15-group-servers-template-vars: |
      import os, urllib.request, yaml

      GROUP_ROLES_URL = os.environ.get("LOBOT_GROUP_ROLES_URL", "https://raw.githubusercontent.com/Queens-School-of-Computing/Lobot/main/group-roles.yaml")

      def _load_group_servers_by_user():
          """
          Build mapping: member_username (lowercase) -> [
              {
                  "owner": group_user,
                  "running": None,       # unknown here
                  "can_manage": True,
              }, ...
          ]
          """
          try:
              raw = urllib.request.urlopen(GROUP_ROLES_URL).read().decode("utf-8")
              data = yaml.safe_load(raw) or {}
          except Exception as e:
              print(f"group-servers-template-vars: failed to fetch {GROUP_ROLES_URL}: {e}")
              return {}

          roles_cfg = data.get("roles", [])
          mapping = {}  # user -> [group dicts]

          for r in roles_cfg:
              group_user = r.get("user")
              members = r.get("members", []) or []
              if not group_user:
                  continue

              for m in members:
                  uname = m.strip().lower()
                  mapping.setdefault(uname, []).append(
                      {
                          "owner": group_user,
                          "running": None,    # we don't know running state here
                          "can_manage": True,
                      }
                  )

          return mapping

      c.JupyterHub.template_vars = getattr(c.JupyterHub, "template_vars", {})
      c.JupyterHub.template_vars["group_servers_by_user"] = _load_group_servers_by_user()
    16-dynamic-announcement: |
      import os, urllib.request, urllib.error, yaml
      from jupyterhub.handlers import BaseHandler

      ANNOUNCEMENT_URL = os.environ.get(
          "LOBOT_ANNOUNCEMENT_URL",
          "https://raw.githubusercontent.com/Queens-School-of-Computing/Lobot/main/announcement.yaml",
      )

      def _fetch_announcement():
          try:
              raw = urllib.request.urlopen(ANNOUNCEMENT_URL, timeout=3).read().decode("utf-8")
              data = yaml.safe_load(raw) or {}
          except Exception as e:
              # Don't break the page if the URL is unreachable
              print(f"[dynamic-announcement] Failed to fetch {ANNOUNCEMENT_URL}: {e}")
              return ""
          text = data.get(os.environ.get("LOBOT_ANNOUNCEMENT_KEY", "announcement_prod"), "") or ""
          return text

      _orig_render_template_announce = BaseHandler.render_template

      def _render_template_with_announcement(self, name, sync=False, **ns):
          try:
              ann = _fetch_announcement()
              # Only set if non-empty; templates can test 'announcement_home'
              if ann:
                  ns.setdefault("announcement_login", ann)
                  ns.setdefault("announcement_home", ann)
                  ns.setdefault("announcement_spawn", ann)
          except Exception as e:
              self.log.error(f"[dynamic-announcement] Error injecting announcement: {e}")
          return _orig_render_template_announce(self, name, sync=sync, **ns)

      BaseHandler.render_template = _render_template_with_announcement
    17-status-page: |
      import tornado.web
      from jupyterhub.handlers import BaseHandler

      class StatusPageHandler(BaseHandler):
          @tornado.web.authenticated
          async def get(self):
              import os, urllib.request, yaml, json
              RUNTIME_URL = os.environ.get("LOBOT_RUNTIME_URL", "https://raw.githubusercontent.com/Queens-School-of-Computing/Lobot/main/runtime_setting.yaml")
              user = self.current_user
              allowed_labs_json = 'null'  # null = admin, sees all
              if not user.admin:
                  try:
                      username = user.name.strip().lower()
                      self.log.info(f'[status-page] username={username}')
                      nodeaccess = (yaml.safe_load(urllib.request.urlopen(RUNTIME_URL, timeout=3).read().decode('utf-8')) or {}).get('nodeaccess', {})
                      self.log.info(f'[status-page] nodeaccess keys={list(nodeaccess.keys())}')

                      def labs_for_user(uname):
                          return [lab for lab, users in nodeaccess.items()
                                  if uname in [u.strip().lower() for u in (users or [])]]

                      allowed = set(labs_for_user(username))
                      self.log.info(f'[status-page] direct labs={allowed}')

                      # Also include labs for group servers the user is a member of.
                      # group_servers_by_user is already in memory from 15-group-servers-template-vars.
                      group_servers_by_user = self.template_namespace.get('group_servers_by_user', {})
                      self.log.info(f'[status-page] group_servers_by_user entry for {username}={group_servers_by_user.get(username)}')
                      for group in group_servers_by_user.get(username, []):
                          owner = (group.get('owner') or '').strip().lower()
                          group_labs = labs_for_user(owner)
                          self.log.info(f'[status-page] group owner={owner} labs={group_labs}')
                          if owner:
                              allowed.update(group_labs)

                      self.log.info(f'[status-page] final allowed={sorted(allowed)}')
                      allowed_labs_json = json.dumps(sorted(allowed))
                  except Exception as e:
                      self.log.error(f'[status-page] Failed to build allowed labs: {e}')
              status_url = f"https://{self.request.host}/allocationstatus/current.json"
              html = await self.render_template('status.html', allowed_labs_json=allowed_labs_json, status_url=status_url)
              self.finish(html)

      c.JupyterHub.extra_handlers = [
          (r'/status', StatusPageHandler),
          (r'/status/', StatusPageHandler),
      ]
