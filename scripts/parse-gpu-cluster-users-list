#!/usr/bin/env python3

import json
import sys
import yaml

from pathlib import Path

output_file = 'runtime_setting.yaml'

denied_resources = [ 'admin' ]
always_included_resources = [ 'lobot_problackwell', 'devlab' ]

def main():
    # XXX Example implementation. Expecting payload like
    # [{"GitHubUsername":"foo","Membership":bar}, ...]
    # from live webhook
    payload = json.loads(Path('./example-payload.json').read_text())

    resource_names = extract_resources_names(payload)
    resources = extract_resources(payload, resource_names)
    pages = get_resource_pages(resource_names)

    config = { 'nodeaccess': resources, **pages }

    yaml.add_representer(str, str_presenter)

    with open(output_file, 'w') as f:
        f.write(get_generated_disclaimer())
        yaml.dump(config, f, indent=2, sort_keys=False)

    print(pages)

def extract_resources_names(payload):
    names = set()

    for item in payload:
        name = item['Membership']
        if name in denied_resources:
            continue

        names.add(name)

    for name in always_included_resources:
        names.add(name)

    return list(names)

# FIXME Can delete this function when we no longer
# care about resource order
def apply_custom_resource_page_sort(resources):
    """
    Custom order for 'from_data_{RESOURCE}' pages.
    Match the output order of the existing file,
    to increase confidence in generated output
    """
    custom_order = {
            'lobot_a40': 0,
            'lobot_problackwell': 1,
            'bamlab': 2,
            'mulab': 3,
            'riselab': 4,
            'lobot_a16': 5,
            'lobot_a5000': 6,
            'miblab': 7,
            'winemocollab': 8,
            'gandslab': 9,
            'edemsmithbusiness': 10,
            'devlab': 11,
            }

    return sorted(resources, key=lambda val: custom_order[val])

# FIXME Can delete this function when we no longer
# care about resource order
def apply_custom_resource_page_sort(resources):
    custom_order = {
            'lobot_a16': 0,
            'lobot_a5000':  1,
            'lobot_a40': 2,
            'lobot_problackwell':  3,
            'mulab': 4,
            'bamlab': 5,
            'riselab': 6,
            'miblab': 7,
            'winemocollab': 8,
            'edemsmithbusiness': 9,
            'gandslab':    10,
            'devlab':   11,
            }

    return sorted(resources, key=lambda val: custom_order[val])

def extract_resources(payload, resource_names):
    """
    Sorts members by resources. Given input of the form
    [
        {"GitHubUsername":"samus","Membership":"nintendo"},
        {"GitHubUsername":"mario","Membership":"nintendo"},
        {"GitHubUsername":"sonic","Membership":"sega"},
    ]
    outputs a dict of the following form
    {
        "nintendo":["samus","mario"],
        "sega":["sonic"],
    }
    """
    resources = {}
    for member in payload:
        res = member['Membership']
        no_res_membership=(not res or not res in resource_names)
        if no_res_membership:
            continue
        if not res in resources:
            resources[res] = []

        resources[res].append(member['GitHubUsername'].lower())

    return resources

# FIXME Eventually get actual resources and build page HTML programmatically
def get_resource_pages(resource_names):
    pages = {}
    for name in apply_custom_resource_page_sort(resource_names):
        with open(f"./assets/html/{name}.html") as f:
            pages[f"from_data_{name}"] = f.read()
    return pages

def parse_memberships(req):
    pass

def get_generated_disclaimer():
    return ("###\n"
            "### NOTE THIS FILE IS AUTOMATICALLY GENERATED\n"
            "### ANY MANUAL EDITS WILL BE OVERWRITTEN\n"
            "### EDIT ./scripts/parse-gpu-cluster-users-list\n"
            "### TO CHANGE THIS FILE PERMANENTLY\n"
            "###\n"
            "\n")

# Custom multiline implementation to preserve nice HTML strings
# https://github.com/yaml/pyyaml/issues/240#issuecomment-1096224358
def str_presenter(dumper, data):
    if data.count('\n') > 0:
        data = "\n".join([line.rstrip() for line in data.splitlines()])
        return dumper.represent_scalar('tag:yaml.org,2002:str', data, style='|')
    return dumper.represent_scalar('tag:yaml.org,2002:str', data)

if __name__ == "__main__":
    main()
    print('---')
