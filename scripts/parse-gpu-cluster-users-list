#!/usr/bin/env python3

import json
import sys
import yaml

from pathlib import Path

output_file = 'runtime_setting.yaml'

denied_resources = [ 'admin' ]
always_included_resources = [ 'lobot_problackwell', 'devlab' ]

def main():
    # XXX Example implementation. Expecting payload like
    # [{"GitHubUsername":"foo","Membership":bar}, ...]
    # from live webhook
    payload = json.loads(Path('./example-payload.json').read_text())

    resources = extract_resources(payload)
    labs = extract_labs(payload, resources)
    pages = get_lab_pages(resources)

    config = { 'nodeaccess': labs, **pages }

    yaml.add_representer(str, str_presenter)

    with open(output_file, 'w') as f:
        f.write(get_generated_disclaimer())
        yaml.dump(config, f, indent=2, sort_keys=False)

    print(pages)

def extract_resources(payload):
    resources = set()

    for item in payload:
        resource = item['Membership']
        if resource in denied_resources:
            continue

        resources.add(resource)

    for resource in always_included_resources:
        resources.add(resource)

    return list(resources)

def extract_labs(payload, resources):
    """
    Sorts members by lab. Given input of the form
    [{"GitHubUsername":"foo","Membership":bar}]
    outs a dict of the following form
    {"bar":["foo"]}
    """
    labs = {}
    for member in payload:
        lab = member['Membership']
        # FIXME Don't extend global lab, just use it for reference
        # FIXME Filter out 'Enabled' == False!
        no_lab_membership=(not lab or not lab in resources)
        if no_lab_membership:
            continue
        if not lab in labs:
            labs[lab] = []

        labs[lab].append(member['GitHubUsername'].lower())

    return labs

# FIXME Eventually get actual resources and build page HTML programmatically
def get_lab_pages(resources):
    pages = {}
    # FIXME TOMORROW-JM: get this from payload (webhook)
    for res in resources:
        with open(f"./assets/html/{res}.html") as f:
            pages[f"from_data_{res}"] = f.read()
    return pages

def parse_memberships(req):
    pass

def get_generated_disclaimer():
    return ("###\n"
            "### NOTE THIS FILE IS AUTOMATICALLY GENERATED\n"
            "### ANY MANUAL EDITS WILL BE OVERWRITTEN\n"
            "### EDIT ./scripts/parse-gpu-cluster-users-list\n"
            "### TO CHANGE THIS FILE PERMANENTLY\n"
            "###\n"
            "\n")

# Custom multiline implementation to preserve nice HTML strings
# https://github.com/yaml/pyyaml/issues/240#issuecomment-1096224358
def str_presenter(dumper, data):
    if data.count('\n') > 0:
        data = "\n".join([line.rstrip() for line in data.splitlines()])
        return dumper.represent_scalar('tag:yaml.org,2002:str', data, style='|')
    return dumper.represent_scalar('tag:yaml.org,2002:str', data)

if __name__ == "__main__":
    main()
    print('---')
