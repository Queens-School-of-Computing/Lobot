/* lobot-tui — dark btop-like theme */

/* ── App shell ── */
Screen {
    background: #0d1117;
    color: #c9d1d9;
}

/* ── Top info bar ── */
#top-bar {
    height: 1;
    background: #161b22;
    color: #58a6ff;
    padding: 0 1;
    content-align: left middle;
}

/* ── Two-column top section: summary | nodes ── */
#top-section {
    height: 1fr;
    layout: horizontal;
    min-height: 10;
    max-height: 18;
}

#summary-panel {
    width: 2fr;
    border: solid #30363d;
    border-title-color: #58a6ff;
    border-title-align: left;
    padding: 0;
}

#summary-panel:focus-within {
    border: solid #e3b341;
    border-title-color: #e3b341;
}

#nodes-panel {
    width: 3fr;
    border: solid #30363d;
    border-title-color: #58a6ff;
    border-title-align: left;
    padding: 0;
}

#nodes-panel:focus-within {
    border: solid #e3b341;
    border-title-color: #e3b341;
}


/* ── Pod table ── */
#pods-panel {
    height: 2fr;
    border: solid #30363d;
    border-title-color: #58a6ff;
    border-title-align: left;
    padding: 0;
    min-height: 8;
}

#pods-panel:focus-within {
    border: solid #e3b341;
    border-title-color: #e3b341;
}

#pod-filter-bar {
    height: 1;
    background: #161b22;
    layout: horizontal;
    padding: 0 1;
}

#pod-filter-label {
    color: #8b949e;
    width: auto;
    content-align: left middle;
}

#pod-filter-input {
    width: 1fr;
    background: #161b22;
    color: #c9d1d9;
    border: none;
    border-bottom: solid #30363d;
}

#pod-filter-input:focus {
    border-bottom: solid #58a6ff;
    background: #0d1117;
}

#pod-count-outer {
    width: auto;
    color: #8b949e;
    content-align: right middle;
    padding-right: 1;
}

/* ── Actions panel ── */
#actions-panel {
    height: 3;
    background: #161b22;
    border-top: solid #30363d;
    padding: 0 1;
    layout: vertical;
}

/* ── Status bar ── */
#status-bar {
    height: 1;
    background: #161b22;
    color: #8b949e;
    padding: 0 1;
    layout: horizontal;
}

#status-live {
    width: auto;
    color: #3fb950;
}

#status-stale {
    width: auto;
    color: #d29922;
}

#status-error {
    width: auto;
    color: #f85149;
}

#status-timestamps {
    width: 1fr;
    content-align: left middle;
    color: #8b949e;
}

#status-hint {
    width: auto;
    color: #8b949e;
    content-align: right middle;
}

/* ── DataTable shared styles ── */
DataTable {
    background: #0d1117;
    color: #c9d1d9;
    border: none;
    height: 1fr;
}

DataTable > .datatable--header {
    background: #161b22;
    color: #58a6ff;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: #1f6feb;
    color: #ffffff;
}

DataTable > .datatable--hover {
    background: #2d333b;
}

.bar-full {
    color: #3fb950;
}

.bar-warn {
    color: #d29922;
}

.bar-crit {
    color: #f85149;
}

/* ── Modal screens ── */
ConfirmScreen {
    align: center middle;
}

#confirm-dialog {
    width: 60;
    height: auto;
    background: #161b22;
    border: solid #58a6ff;
    padding: 1 2;
}

#confirm-title {
    text-style: bold;
    color: #f85149;
    margin-bottom: 1;
}

#confirm-message {
    color: #c9d1d9;
    margin-bottom: 1;
}

#confirm-buttons {
    layout: horizontal;
    height: auto;
    align: right middle;
}

#confirm-buttons Button {
    margin-left: 1;
}

/* ── Action wizard ── */
ActionWizardScreen {
    align: center middle;
}

#wizard-dialog {
    width: 90;
    height: auto;
    max-height: 80%;
    background: #161b22;
    border: solid #58a6ff;
    padding: 1 2;
    overflow-y: auto;
}

#wizard-title {
    text-style: bold;
    color: #58a6ff;
    margin-bottom: 1;
}

.wizard-field-label {
    color: #8b949e;
    margin-top: 1;
}

.wizard-input {
    background: #0d1117;
    border: solid #30363d;
    color: #c9d1d9;
    width: 1fr;
}

.wizard-checkbox {
    margin-top: 1;
    color: #c9d1d9;
}

.wizard-checkbox-row {
    height: auto;
    margin-top: 1;
}

.wizard-checkbox-row Checkbox {
    margin-right: 2;
}

#wizard-buttons {
    layout: horizontal;
    height: auto;
    margin-top: 1;
    align: right middle;
}

#wizard-buttons Button {
    margin-left: 1;
}

.wizard-select {
    width: 1fr;
    margin-top: 0;
}

.wizard-selection-list {
    width: 1fr;
    height: auto;
    max-height: 8;
    border: solid #30363d;
    background: #0d1117;
}

/* ── Node picker modal ── */
NodePickerScreen {
    align: center middle;
}

#node-picker-dialog {
    width: 50;
    height: auto;
    max-height: 70%;
    background: #161b22;
    border: solid #58a6ff;
    padding: 1 2;
}

#node-picker-title {
    text-style: bold;
    color: #58a6ff;
    margin-bottom: 1;
}

#node-picker-list {
    height: auto;
    max-height: 20;
    overflow-y: auto;
}

#node-picker-buttons {
    layout: horizontal;
    height: auto;
    margin-top: 1;
    align: right middle;
}

#node-picker-buttons Button {
    margin-left: 1;
}

/* ── Command preview modal ── */
CommandPreviewScreen {
    align: center middle;
}

#preview-dialog {
    width: 80;
    height: auto;
    max-height: 80%;
    background: #161b22;
    border: solid #f85149;
    padding: 1 2;
}

#preview-title {
    text-style: bold;
    color: #f85149;
    margin-bottom: 1;
}

#preview-warning {
    color: #c9d1d9;
    margin-bottom: 1;
}

.preview-section-label {
    color: #8b949e;
    margin-top: 1;
}

#preview-command {
    background: #0d1117;
    border: solid #30363d;
    color: #79c0ff;
    padding: 1;
    margin-top: 0;
}

#preview-hint {
    color: #8b949e;
    margin-top: 1;
}

#preview-buttons {
    layout: horizontal;
    height: auto;
    margin-top: 1;
    align: right middle;
}

#preview-buttons Button {
    margin-left: 1;
}

/* ── Logs / Action / Detail / Jobs screens ── */
LogsScreen, ActionScreen, PodDetailScreen, JobsScreen, ConsoleScreen {
    background: #0d1117;
}

#screen-header {
    height: 1;
    background: #161b22;
    color: #58a6ff;
    padding: 0 1;
}

#screen-log {
    height: 1fr;
    background: #0d1117;
    color: #c9d1d9;
    border: none;
    scrollbar-color: #30363d;
}

#screen-footer {
    height: 1;
    background: #161b22;
    color: #8b949e;
    padding: 0 1;
}

/* ── Announcement editor modal ── */
AnnouncementScreen {
    align: center middle;
}

#announcement-dialog {
    width: 80;
    height: auto;
    background: #161b22;
    border: solid #58a6ff;
    padding: 1 2;
}

#announcement-title {
    text-style: bold;
    color: #58a6ff;
    margin-bottom: 0;
}

#announcement-footer {
    height: 1;
    color: #8b949e;
    margin-top: 1;
}

#announcement-buttons {
    layout: horizontal;
    height: auto;
    margin-top: 1;
    align: right middle;
}

#announcement-buttons Button {
    margin-left: 1;
}

/* ── Help screen ── */
HelpScreen {
    align: center middle;
}

#help-dialog {
    width: 80;
    height: 80%;
    background: #161b22;
    border: solid #58a6ff;
    padding: 1 2;
    overflow-y: auto;
}

#help-title {
    text-style: bold;
    color: #58a6ff;
    margin-bottom: 1;
}

/* ── Node status colours ── */
.node-ready {
    color: #3fb950;
}

.node-notready {
    color: #f85149;
}

.node-cordoned {
    color: #d29922;
}

.node-ctrl {
    color: #8b949e;
}

/* ── Pod phase colours ── */
.phase-running {
    color: #3fb950;
}

.phase-pending {
    color: #d29922;
}

.phase-failed {
    color: #f85149;
}

.phase-unknown {
    color: #8b949e;
}
